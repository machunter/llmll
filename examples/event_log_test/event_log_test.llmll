;; Event Log Integration Test (v0.3.1)
;;
;; Minimal console program that echoes input.
;; When compiled and run, produces a .event-log.jsonl file.
;;
;; Test procedure:
;;   1. llmll build event_log_test.llmll
;;   2. Run the generated program with stdin: "hello\nworld\n"
;;   3. Verify event_log_test.event-log.jsonl exists
;;   4. Verify it contains 2 event lines
;;   5. llmll replay event_log_test.llmll event_log_test.event-log.jsonl
;;   6. Verify replay reports 2 events matched

(import wasi.io (capability stdout :deterministic false))

(def-logic echo-step [state: string input: string]
  (pair state (wasi.io.stdout input)))

(def-main :mode console
  :step echo-step)
