{
  "schemaVersion": "0.1.2",
  "llmll_version": "0.1.2",
  "statements": [
    {
      "kind": "import",
      "path": "wasi.io",
      "capability": { "name": "stdout" }
    },
    {
      "kind": "import",
      "path": "wasi.io",
      "capability": { "name": "stdin", "deterministic": true }
    },
    {
      "kind": "type-decl",
      "name": "Word",
      "body": {
        "kind": "where",
        "binding": "s",
        "base_type": { "kind": "primitive", "name": "string" },
        "predicate": {
          "kind": "op",
          "op": ">",
          "args": [
            { "kind": "app", "fn": "string-length", "args": [ { "kind": "var", "name": "s" } ] },
            { "kind": "lit-int", "value": 0 }
          ]
        }
      }
    },
    {
      "kind": "type-decl",
      "name": "Letter",
      "body": {
        "kind": "where",
        "binding": "s",
        "base_type": { "kind": "primitive", "name": "string" },
        "predicate": {
          "kind": "op",
          "op": "=",
          "args": [
            { "kind": "app", "fn": "string-length", "args": [ { "kind": "var", "name": "s" } ] },
            { "kind": "lit-int", "value": 1 }
          ]
        }
      }
    },
    {
      "kind": "type-decl",
      "name": "GuessCount",
      "body": {
        "kind": "where",
        "binding": "n",
        "base_type": { "kind": "primitive", "name": "int" },
        "predicate": {
          "kind": "op",
          "op": ">=",
          "args": [
            { "kind": "var", "name": "n" },
            { "kind": "lit-int", "value": 0 }
          ]
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "make-state",
      "params": [
        { "name": "w", "param_type": { "kind": "named", "name": "Word" } },
        { "name": "g", "param_type": { "kind": "list", "elem_type": { "kind": "named", "name": "Letter" } } },
        { "name": "wc", "param_type": { "kind": "named", "name": "GuessCount" } },
        { "name": "mx", "param_type": { "kind": "named", "name": "GuessCount" } }
      ],
      "body": {
        "kind": "pair",
        "fst": { "kind": "var", "name": "w" },
        "snd": {
          "kind": "pair",
          "fst": { "kind": "var", "name": "g" },
          "snd": {
            "kind": "pair",
            "fst": { "kind": "var", "name": "wc" },
            "snd": { "kind": "var", "name": "mx" }
          }
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "state-word",
      "params": [ { "name": "s" } ],
      "body": { "kind": "app", "fn": "first", "args": [ { "kind": "var", "name": "s" } ] }
    },
    {
      "kind": "def-logic",
      "name": "state-guessed",
      "params": [ { "name": "s" } ],
      "body": { "kind": "app", "fn": "first", "args": [ { "kind": "app", "fn": "second", "args": [ { "kind": "var", "name": "s" } ] } ] }
    },
    {
      "kind": "def-logic",
      "name": "state-wrong",
      "params": [ { "name": "s" } ],
      "body": { "kind": "app", "fn": "first", "args": [ { "kind": "app", "fn": "second", "args": [ { "kind": "app", "fn": "second", "args": [ { "kind": "var", "name": "s" } ] } ] } ] }
    },
    {
      "kind": "def-logic",
      "name": "state-max",
      "params": [ { "name": "s" } ],
      "body": { "kind": "app", "fn": "second", "args": [ { "kind": "app", "fn": "second", "args": [ { "kind": "app", "fn": "second", "args": [ { "kind": "var", "name": "s" } ] } ] } ] }
    },
    {
      "kind": "def-logic",
      "name": "all-guessed?",
      "params": [
        { "name": "word", "param_type": { "kind": "named", "name": "Word" } },
        { "name": "guessed", "param_type": { "kind": "list", "elem_type": { "kind": "named", "name": "Letter" } } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "n",
            "expr": { "kind": "app", "fn": "string-length", "args": [ { "kind": "var", "name": "word" } ] }
          },
          {
            "name": "indices",
            "expr": { "kind": "app", "fn": "range", "args": [ { "kind": "lit-int", "value": 0 }, { "kind": "var", "name": "n" } ] }
          }
        ],
        "body": {
          "kind": "app",
          "fn": "list-fold",
          "args": [
            { "kind": "var", "name": "indices" },
            { "kind": "lit-bool", "value": true },
            {
              "kind": "lambda",
              "params": [ { "name": "acc" }, { "name": "i" } ],
              "body": {
                "kind": "op",
                "op": "and",
                "args": [
                  { "kind": "var", "name": "acc" },
                  {
                    "kind": "app",
                    "fn": "list-contains",
                    "args": [
                      { "kind": "var", "name": "guessed" },
                      { "kind": "app", "fn": "string-char-at", "args": [ { "kind": "var", "name": "word" }, { "kind": "var", "name": "i" } ] }
                    ]
                  }
                ]
              }
            }
          ]
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "display-word",
      "params": [
        { "name": "word", "param_type": { "kind": "named", "name": "Word" } },
        { "name": "guessed", "param_type": { "kind": "list", "elem_type": { "kind": "named", "name": "Letter" } } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "n",
            "expr": { "kind": "app", "fn": "string-length", "args": [ { "kind": "var", "name": "word" } ] }
          },
          {
            "name": "indices",
            "expr": { "kind": "app", "fn": "range", "args": [ { "kind": "lit-int", "value": 0 }, { "kind": "var", "name": "n" } ] }
          }
        ],
        "body": {
          "kind": "app",
          "fn": "list-fold",
          "args": [
            { "kind": "var", "name": "indices" },
            { "kind": "lit-string", "value": "" },
            {
              "kind": "lambda",
              "params": [ { "name": "acc" }, { "name": "i" } ],
              "body": {
                "kind": "let",
                "bindings": [
                  {
                    "name": "c",
                    "expr": { "kind": "app", "fn": "string-char-at", "args": [ { "kind": "var", "name": "word" }, { "kind": "var", "name": "i" } ] }
                  },
                  {
                    "name": "display-char",
                    "expr": {
                      "kind": "if",
                      "cond": { "kind": "app", "fn": "list-contains", "args": [ { "kind": "var", "name": "guessed" }, { "kind": "var", "name": "c" } ] },
                      "then_branch": { "kind": "var", "name": "c" },
                      "else_branch": { "kind": "lit-string", "value": "_" }
                    }
                  }
                ],
                "body": {
                  "kind": "app",
                  "fn": "string-concat",
                  "args": [
                    { "kind": "app", "fn": "string-concat", "args": [ { "kind": "var", "name": "acc" }, { "kind": "var", "name": "display-char" } ] },
                    { "kind": "lit-string", "value": " " }
                  ]
                }
              }
            }
          ]
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "guess",
      "params": [
        { "name": "state" },
        { "name": "l", "param_type": { "kind": "named", "name": "Letter" } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          { "name": "word", "expr": { "kind": "app", "fn": "state-word", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "guessed", "expr": { "kind": "app", "fn": "state-guessed", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "wrong", "expr": { "kind": "app", "fn": "state-wrong", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "max-w", "expr": { "kind": "app", "fn": "state-max", "args": [ { "kind": "var", "name": "state" } ] } }
        ],
        "body": {
          "kind": "if",
          "cond": { "kind": "app", "fn": "list-contains", "args": [ { "kind": "var", "name": "guessed" }, { "kind": "var", "name": "l" } ] },
          "then_branch": { "kind": "var", "name": "state" },
          "else_branch": {
            "kind": "let",
            "bindings": [
              {
                "name": "new-guessed",
                "expr": { "kind": "app", "fn": "list-append", "args": [ { "kind": "var", "name": "guessed" }, { "kind": "var", "name": "l" } ] }
              },
              {
                "name": "is-correct",
                "expr": { "kind": "app", "fn": "string-contains", "args": [ { "kind": "var", "name": "word" }, { "kind": "var", "name": "l" } ] }
              },
              {
                "name": "new-wrong",
                "expr": {
                  "kind": "if",
                  "cond": { "kind": "var", "name": "is-correct" },
                  "then_branch": { "kind": "var", "name": "wrong" },
                  "else_branch": { "kind": "op", "op": "+", "args": [ { "kind": "var", "name": "wrong" }, { "kind": "lit-int", "value": 1 } ] }
                }
              }
            ],
            "body": {
              "kind": "app",
              "fn": "make-state",
              "args": [
                { "kind": "var", "name": "word" },
                { "kind": "var", "name": "new-guessed" },
                { "kind": "var", "name": "new-wrong" },
                { "kind": "var", "name": "max-w" }
              ]
            }
          }
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "game-loop",
      "params": [
        { "name": "state" },
        { "name": "input", "param_type": { "kind": "primitive", "name": "string" } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          { "name": "word", "expr": { "kind": "app", "fn": "state-word", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "wrong", "expr": { "kind": "app", "fn": "state-wrong", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "max-w", "expr": { "kind": "app", "fn": "state-max", "args": [ { "kind": "var", "name": "state" } ] } }
        ],
        "body": {
          "kind": "if",
          "cond": { "kind": "op", "op": "=", "args": [ { "kind": "app", "fn": "string-length", "args": [ { "kind": "var", "name": "input" } ] }, { "kind": "lit-int", "value": 1 } ] },
          "then_branch": {
            "kind": "let",
            "bindings": [
              { "name": "new-state", "expr": { "kind": "app", "fn": "guess", "args": [ { "kind": "var", "name": "state" }, { "kind": "var", "name": "input" } ] } },
              { "name": "new-guessed", "expr": { "kind": "app", "fn": "state-guessed", "args": [ { "kind": "var", "name": "new-state" } ] } },
              { "name": "new-wrong", "expr": { "kind": "app", "fn": "state-wrong", "args": [ { "kind": "var", "name": "new-state" } ] } }
            ],
            "body": {
              "kind": "if",
              "cond": { "kind": "app", "fn": "all-guessed?", "args": [ { "kind": "var", "name": "word" }, { "kind": "var", "name": "new-guessed" } ] },
              "then_branch": {
                "kind": "pair",
                "fst": { "kind": "var", "name": "new-state" },
                "snd": { "kind": "qual-app", "qual_fn": "wasi.io.stdout", "args": [ { "kind": "app", "fn": "string-concat", "args": [ { "kind": "lit-string", "value": "WIN! The word was: " }, { "kind": "var", "name": "word" } ] } ] }
              },
              "else_branch": {
                "kind": "if",
                "cond": { "kind": "op", "op": ">=", "args": [ { "kind": "var", "name": "new-wrong" }, { "kind": "var", "name": "max-w" } ] },
                "then_branch": {
                  "kind": "pair",
                  "fst": { "kind": "var", "name": "new-state" },
                  "snd": { "kind": "qual-app", "qual_fn": "wasi.io.stdout", "args": [ { "kind": "app", "fn": "string-concat", "args": [ { "kind": "lit-string", "value": "LOSE! The word was: " }, { "kind": "var", "name": "word" } ] } ] }
                },
                "else_branch": {
                  "kind": "pair",
                  "fst": { "kind": "var", "name": "new-state" },
                  "snd": {
                    "kind": "qual-app",
                    "qual_fn": "wasi.io.stdout",
                    "args": [
                      {
                        "kind": "app",
                        "fn": "string-concat",
                        "args": [
                          { "kind": "app", "fn": "display-word", "args": [ { "kind": "var", "name": "word" }, { "kind": "var", "name": "new-guessed" } ] },
                          { "kind": "app", "fn": "string-concat", "args": [ { "kind": "lit-string", "value": " | Wrong: " }, { "kind": "app", "fn": "int-to-string", "args": [ { "kind": "var", "name": "new-wrong" } ] } ] }
                        ]
                      }
                    ]
                  }
                }
              }
            }
          },
          "else_branch": {
            "kind": "pair",
            "fst": { "kind": "var", "name": "state" },
            "snd": { "kind": "qual-app", "qual_fn": "wasi.io.stdout", "args": [ { "kind": "lit-string", "value": "Invalid input! Please enter exactly one letter." } ] }
          }
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "start-game",
      "params": [
        { "name": "word", "param_type": { "kind": "named", "name": "Word" } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "initial-state",
            "expr": {
              "kind": "app",
              "fn": "make-state",
              "args": [
                { "kind": "var", "name": "word" },
                { "kind": "app", "fn": "list-empty", "args": [] },
                { "kind": "lit-int", "value": 0 },
                { "kind": "lit-int", "value": 6 }
              ]
            }
          }
        ],
        "body": {
          "kind": "pair",
          "fst": { "kind": "var", "name": "initial-state" },
          "snd": {
            "kind": "qual-app",
            "qual_fn": "wasi.io.stdout",
            "args": [
              {
                "kind": "app",
                "fn": "string-concat",
                "args": [
                  { "kind": "lit-string", "value": "Welcome to Hangman!\n" },
                  { "kind": "app", "fn": "display-word", "args": [ { "kind": "var", "name": "word" }, { "kind": "app", "fn": "list-empty", "args": [] } ] }
                ]
              }
            ]
          }
        }
      }
    },
    {
      "kind": "def-logic",
      "name": "is-game-over?",
      "params": [ { "name": "state" } ],
      "body": {
        "kind": "let",
        "bindings": [
          { "name": "word", "expr": { "kind": "app", "fn": "state-word", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "guessed", "expr": { "kind": "app", "fn": "state-guessed", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "wrong", "expr": { "kind": "app", "fn": "state-wrong", "args": [ { "kind": "var", "name": "state" } ] } },
          { "name": "max-w", "expr": { "kind": "app", "fn": "state-max", "args": [ { "kind": "var", "name": "state" } ] } }
        ],
        "body": {
          "kind": "op",
          "op": "or",
          "args": [
            { "kind": "app", "fn": "all-guessed?", "args": [ { "kind": "var", "name": "word" }, { "kind": "var", "name": "guessed" } ] },
            { "kind": "op", "op": ">=", "args": [ { "kind": "var", "name": "wrong" }, { "kind": "var", "name": "max-w" } ] }
          ]
        }
      }
    },
    {
      "kind": "def-main",
      "mode": "console",
      "init": {
        "kind": "app",
        "fn": "start-game",
        "args": [ { "kind": "lit-string", "value": "hangman" } ]
      },
      "step": { "kind": "var", "name": "game-loop" },
      "done?": { "kind": "var", "name": "is-game-over?" }
    }
  ]
}
