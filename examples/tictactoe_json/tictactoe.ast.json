{
  "schemaVersion": "0.1.2",
  "llmll_version": "0.1.2",
  "source_file": "tictactoe.ast.json",
  "statements": [

    {
      "kind": "import",
      "path": "wasi.io",
      "capability": { "name": "stdout", "deterministic": false }
    },
    {
      "kind": "import",
      "path": "wasi.io",
      "capability": { "name": "stdin", "deterministic": true }
    },

    {
      "kind": "def-logic",
      "name": "init-board",
      "params": [],
      "body": {
        "kind": "let",
        "bindings": [
          { "name": "b0", "expr": {"kind": "app", "fn": "list-empty", "args": []} },
          { "name": "b1", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b0"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b2", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b1"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b3", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b2"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b4", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b3"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b5", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b4"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b6", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b5"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b7", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b6"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b8", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b7"}, {"kind": "lit-string", "value": " "}]} },
          { "name": "b9", "expr": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "b8"}, {"kind": "lit-string", "value": " "}]} }
        ],
        "body": {"kind": "var", "name": "b9"}
      }
    },

    {
      "kind": "def-logic",
      "name": "make-state",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}},
        {"name": "player", "param_type": {"kind": "primitive", "name": "string"}},
        {"name": "gameover", "param_type": {"kind": "primitive", "name": "bool"}},
        {"name": "winner", "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "pair",
        "fst": {"kind": "var", "name": "board"},
        "snd": {
          "kind": "pair",
          "fst": {"kind": "var", "name": "player"},
          "snd": {
            "kind": "pair",
            "fst": {"kind": "var", "name": "gameover"},
            "snd": {"kind": "var", "name": "winner"}
          }
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "state-board",
      "params": [{"name": "s", "untyped": true, "comment": "(list[string], (string, (bool, string)))"}],
      "body": {"kind": "app", "fn": "first", "args": [{"kind": "var", "name": "s"}]}
    },

    {
      "kind": "def-logic",
      "name": "state-player",
      "params": [{"name": "s", "untyped": true, "comment": "(list[string], (string, (bool, string)))"}],
      "body": {"kind": "app", "fn": "first", "args": [{"kind": "app", "fn": "second", "args": [{"kind": "var", "name": "s"}]}]}
    },

    {
      "kind": "def-logic",
      "name": "state-gameover",
      "params": [{"name": "s", "untyped": true, "comment": "(list[string], (string, (bool, string)))"}],
      "body": {
        "kind": "app", "fn": "first",
        "args": [{"kind": "app", "fn": "second", "args": [{"kind": "app", "fn": "second", "args": [{"kind": "var", "name": "s"}]}]}]
      }
    },

    {
      "kind": "def-logic",
      "name": "state-winner",
      "params": [{"name": "s", "untyped": true, "comment": "(list[string], (string, (bool, string)))"}],
      "body": {
        "kind": "app", "fn": "second",
        "args": [{"kind": "app", "fn": "second", "args": [{"kind": "app", "fn": "second", "args": [{"kind": "var", "name": "s"}]}]}]
      }
    },

    {
      "kind": "def-logic",
      "name": "cell-at",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}},
        {"name": "idx", "param_type": {"kind": "primitive", "name": "int"}}
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "sliced",
            "expr": {
              "kind": "app", "fn": "list-fold",
              "args": [
                {"kind": "var", "name": "board"},
                {"kind": "pair",
                  "fst": {"kind": "lit-string", "value": " "},
                  "snd": {"kind": "lit-int", "value": 0}
                },
                {
                  "kind": "lambda",
                  "params": [{"name": "acc"}, {"name": "cell"}],
                  "body": {
                    "kind": "let",
                    "bindings": [
                      {"name": "cur-val",  "expr": {"kind": "app", "fn": "first",  "args": [{"kind": "var", "name": "acc"}]}},
                      {"name": "cur-i",    "expr": {"kind": "app", "fn": "second", "args": [{"kind": "var", "name": "acc"}]}}
                    ],
                    "body": {
                      "kind": "if",
                      "cond": {"kind": "op", "op": "=", "args": [{"kind": "var", "name": "cur-i"}, {"kind": "var", "name": "idx"}]},
                      "then_branch": {
                        "kind": "pair",
                        "fst": {"kind": "var", "name": "cell"},
                        "snd": {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "cur-i"}, {"kind": "lit-int", "value": 1}]}
                      },
                      "else_branch": {
                        "kind": "pair",
                        "fst": {"kind": "var", "name": "cur-val"},
                        "snd": {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "cur-i"}, {"kind": "lit-int", "value": 1}]}
                      }
                    }
                  }
                }
              ]
            }
          }
        ],
        "body": {"kind": "app", "fn": "first", "args": [{"kind": "var", "name": "sliced"}]}
      }
    },

    {
      "kind": "def-logic",
      "name": "set-cell",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}},
        {"name": "idx",   "param_type": {"kind": "primitive", "name": "int"}},
        {"name": "val",   "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "result-pair",
            "expr": {
              "kind": "app", "fn": "list-fold",
              "args": [
                {"kind": "var", "name": "board"},
                {"kind": "pair",
                  "fst": {"kind": "app", "fn": "list-empty", "args": []},
                  "snd": {"kind": "lit-int", "value": 0}
                },
                {
                  "kind": "lambda",
                  "params": [{"name": "acc"}, {"name": "cell"}],
                  "body": {
                    "kind": "let",
                    "bindings": [
                      {"name": "new-board", "expr": {"kind": "app", "fn": "first",  "args": [{"kind": "var", "name": "acc"}]}},
                      {"name": "cur-i",     "expr": {"kind": "app", "fn": "second", "args": [{"kind": "var", "name": "acc"}]}}
                    ],
                    "body": {
                      "kind": "if",
                      "cond": {"kind": "op", "op": "=", "args": [{"kind": "var", "name": "cur-i"}, {"kind": "var", "name": "idx"}]},
                      "then_branch": {
                        "kind": "pair",
                        "fst": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "new-board"}, {"kind": "var", "name": "val"}]},
                        "snd": {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "cur-i"}, {"kind": "lit-int", "value": 1}]}
                      },
                      "else_branch": {
                        "kind": "pair",
                        "fst": {"kind": "app", "fn": "list-append", "args": [{"kind": "var", "name": "new-board"}, {"kind": "var", "name": "cell"}]},
                        "snd": {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "cur-i"}, {"kind": "lit-int", "value": 1}]}
                      }
                    }
                  }
                }
              ]
            }
          }
        ],
        "body": {"kind": "app", "fn": "first", "args": [{"kind": "var", "name": "result-pair"}]}
      }
    },

    {
      "kind": "def-logic",
      "name": "three-match?",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}},
        {"name": "a", "param_type": {"kind": "primitive", "name": "int"}},
        {"name": "b", "param_type": {"kind": "primitive", "name": "int"}},
        {"name": "c", "param_type": {"kind": "primitive", "name": "int"}},
        {"name": "p", "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "op", "op": "and",
        "args": [
          {"kind": "op", "op": "=", "args": [{"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "var", "name": "a"}]}, {"kind": "var", "name": "p"}]},
          {"kind": "op", "op": "and",
            "args": [
              {"kind": "op", "op": "=", "args": [{"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "var", "name": "b"}]}, {"kind": "var", "name": "p"}]},
              {"kind": "op", "op": "=", "args": [{"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "var", "name": "c"}]}, {"kind": "var", "name": "p"}]}
            ]
          }
        ]
      }
    },

    {
      "kind": "def-logic",
      "name": "player-wins?",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}},
        {"name": "p", "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "op", "op": "or",
        "args": [
          {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 0}, {"kind": "lit-int", "value": 1}, {"kind": "lit-int", "value": 2}, {"kind": "var", "name": "p"}]},
          {"kind": "op", "op": "or",
            "args": [
              {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 3}, {"kind": "lit-int", "value": 4}, {"kind": "lit-int", "value": 5}, {"kind": "var", "name": "p"}]},
              {"kind": "op", "op": "or",
                "args": [
                  {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 6}, {"kind": "lit-int", "value": 7}, {"kind": "lit-int", "value": 8}, {"kind": "var", "name": "p"}]},
                  {"kind": "op", "op": "or",
                    "args": [
                      {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 0}, {"kind": "lit-int", "value": 3}, {"kind": "lit-int", "value": 6}, {"kind": "var", "name": "p"}]},
                      {"kind": "op", "op": "or",
                        "args": [
                          {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 1}, {"kind": "lit-int", "value": 4}, {"kind": "lit-int", "value": 7}, {"kind": "var", "name": "p"}]},
                          {"kind": "op", "op": "or",
                            "args": [
                              {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 2}, {"kind": "lit-int", "value": 5}, {"kind": "lit-int", "value": 8}, {"kind": "var", "name": "p"}]},
                              {"kind": "op", "op": "or",
                                "args": [
                                  {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 0}, {"kind": "lit-int", "value": 4}, {"kind": "lit-int", "value": 8}, {"kind": "var", "name": "p"}]},
                                  {"kind": "app", "fn": "three-match?", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 2}, {"kind": "lit-int", "value": 4}, {"kind": "lit-int", "value": 6}, {"kind": "var", "name": "p"}]}
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },

    {
      "kind": "def-logic",
      "name": "board-full?",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}}
      ],
      "body": {
        "kind": "op", "op": "not",
        "args": [
          {"kind": "app", "fn": "list-contains", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-string", "value": " "}]}
        ]
      }
    },

    {
      "kind": "def-logic",
      "name": "next-player",
      "params": [
        {"name": "p", "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "if",
        "cond": {"kind": "op", "op": "=", "args": [{"kind": "var", "name": "p"}, {"kind": "lit-string", "value": "X"}]},
        "then_branch": {"kind": "lit-string", "value": "O"},
        "else_branch": {"kind": "lit-string", "value": "X"}
      }
    },

    {
      "kind": "def-logic",
      "name": "render-row",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}},
        {"name": "offset", "param_type": {"kind": "primitive", "name": "int"}}
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {"name": "c0", "expr": {"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "var", "name": "offset"}]}},
          {"name": "c1", "expr": {"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "offset"}, {"kind": "lit-int", "value": 1}]}]}},
          {"name": "c2", "expr": {"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "offset"}, {"kind": "lit-int", "value": 2}]}]}}
        ],
        "body": {
          "kind": "app", "fn": "string-concat",
          "args": [
            {"kind": "lit-string", "value": " "},
            {"kind": "app", "fn": "string-concat",
              "args": [
                {"kind": "var", "name": "c0"},
                {"kind": "app", "fn": "string-concat",
                  "args": [
                    {"kind": "lit-string", "value": " | "},
                    {"kind": "app", "fn": "string-concat",
                      "args": [
                        {"kind": "var", "name": "c1"},
                        {"kind": "app", "fn": "string-concat",
                          "args": [
                            {"kind": "lit-string", "value": " | "},
                            {"kind": "var", "name": "c2"}
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "render-board",
      "params": [
        {"name": "board", "param_type": {"kind": "list", "elem_type": {"kind": "primitive", "name": "string"}}}
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {"name": "sep",  "expr": {"kind": "lit-string", "value": "\n---+---+---\n"}},
          {"name": "row0", "expr": {"kind": "app", "fn": "render-row", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 0}]}},
          {"name": "row1", "expr": {"kind": "app", "fn": "render-row", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 3}]}},
          {"name": "row2", "expr": {"kind": "app", "fn": "render-row", "args": [{"kind": "var", "name": "board"}, {"kind": "lit-int", "value": 6}]}}
        ],
        "body": {
          "kind": "app", "fn": "string-concat",
          "args": [
            {"kind": "var", "name": "row0"},
            {"kind": "app", "fn": "string-concat",
              "args": [
                {"kind": "var", "name": "sep"},
                {"kind": "app", "fn": "string-concat",
                  "args": [
                    {"kind": "var", "name": "row1"},
                    {"kind": "app", "fn": "string-concat",
                      "args": [
                        {"kind": "var", "name": "sep"},
                        {"kind": "var", "name": "row2"}
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "make-move",
      "params": [
        {"name": "state", "untyped": true, "comment": "(list[string], (string, (bool, string)))"},
        {"name": "input", "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {"name": "board",     "expr": {"kind": "app", "fn": "state-board",    "args": [{"kind": "var", "name": "state"}]}},
          {"name": "player",    "expr": {"kind": "app", "fn": "state-player",   "args": [{"kind": "var", "name": "state"}]}},
          {"name": "trimmed",   "expr": {"kind": "app", "fn": "string-slice",   "args": [{"kind": "var", "name": "input"}, {"kind": "lit-int", "value": 0}, {"kind": "app", "fn": "string-length", "args": [{"kind": "var", "name": "input"}]}]}},
          {"name": "parse-res", "expr": {"kind": "app", "fn": "string-to-int",  "args": [{"kind": "var", "name": "trimmed"}]}}
        ],
        "body": {
          "kind": "match",
          "scrutinee": {"kind": "var", "name": "parse-res"},
          "arms": [
            {
              "pattern": {"kind": "constructor", "constructor": "Left", "sub_patterns": [{"kind": "bind", "name": "_err"}]},
              "body": {
                "kind": "pair",
                "fst": {"kind": "var", "name": "state"},
                "snd": {
                  "kind": "qual-app", "qual_fn": "wasi.io.stdout",
                  "args": [{"kind": "lit-string", "value": "Invalid input — enter a number 0-8.\n"}]
                }
              }
            },
            {
              "pattern": {"kind": "constructor", "constructor": "Right", "sub_patterns": [{"kind": "bind", "name": "idx"}]},
              "body": {
                "kind": "if",
                "cond": {
                  "kind": "op", "op": "or",
                  "args": [
                    {"kind": "op", "op": "<",  "args": [{"kind": "var", "name": "idx"}, {"kind": "lit-int", "value": 0}]},
                    {"kind": "op", "op": ">=", "args": [{"kind": "var", "name": "idx"}, {"kind": "lit-int", "value": 9}]}
                  ]
                },
                "then_branch": {
                  "kind": "pair",
                  "fst": {"kind": "var", "name": "state"},
                  "snd": {
                    "kind": "qual-app", "qual_fn": "wasi.io.stdout",
                    "args": [{"kind": "lit-string", "value": "Out of range — enter 0-8.\n"}]
                  }
                },
                "else_branch": {
                  "kind": "let",
                  "bindings": [
                    {"name": "current-cell", "expr": {"kind": "app", "fn": "cell-at", "args": [{"kind": "var", "name": "board"}, {"kind": "var", "name": "idx"}]}}
                  ],
                  "body": {
                    "kind": "if",
                    "cond": {
                      "kind": "op", "op": "!=",
                      "args": [{"kind": "var", "name": "current-cell"}, {"kind": "lit-string", "value": " "}]
                    },
                    "then_branch": {
                      "kind": "pair",
                      "fst": {"kind": "var", "name": "state"},
                      "snd": {
                        "kind": "qual-app", "qual_fn": "wasi.io.stdout",
                        "args": [{"kind": "lit-string", "value": "Cell already taken — choose another.\n"}]
                      }
                    },
                    "else_branch": {
                      "kind": "let",
                      "bindings": [
                        {"name": "new-board",  "expr": {"kind": "app", "fn": "set-cell",      "args": [{"kind": "var", "name": "board"}, {"kind": "var", "name": "idx"}, {"kind": "var", "name": "player"}]}},
                        {"name": "won",        "expr": {"kind": "app", "fn": "player-wins?",  "args": [{"kind": "var", "name": "new-board"}, {"kind": "var", "name": "player"}]}},
                        {"name": "full",       "expr": {"kind": "app", "fn": "board-full?",   "args": [{"kind": "var", "name": "new-board"}]}},
                        {"name": "is-draw",    "expr": {"kind": "op", "op": "and", "args": [{"kind": "var", "name": "full"}, {"kind": "op", "op": "not", "args": [{"kind": "var", "name": "won"}]}]}},
                        {"name": "over",       "expr": {"kind": "op", "op": "or",  "args": [{"kind": "var", "name": "won"}, {"kind": "var", "name": "is-draw"}]}},
                        {"name": "win-str",    "expr": {
                          "kind": "if",
                          "cond": {"kind": "var", "name": "won"},
                          "then_branch": {"kind": "var", "name": "player"},
                          "else_branch": {
                            "kind": "if",
                            "cond": {"kind": "var", "name": "is-draw"},
                            "then_branch": {"kind": "lit-string", "value": "draw"},
                            "else_branch": {"kind": "lit-string", "value": ""}
                          }
                        }},
                        {"name": "new-state",  "expr": {"kind": "app", "fn": "make-state",   "args": [{"kind": "var", "name": "new-board"}, {"kind": "app", "fn": "next-player", "args": [{"kind": "var", "name": "player"}]}, {"kind": "var", "name": "over"}, {"kind": "var", "name": "win-str"}]}},
                        {"name": "board-str",  "expr": {"kind": "app", "fn": "render-board", "args": [{"kind": "var", "name": "new-board"}]}},
                        {"name": "status-msg", "expr": {
                          "kind": "if",
                          "cond": {"kind": "var", "name": "won"},
                          "then_branch": {
                            "kind": "app", "fn": "string-concat",
                            "args": [
                              {"kind": "lit-string", "value": "\nPlayer "},
                              {"kind": "app", "fn": "string-concat",
                                "args": [
                                  {"kind": "var", "name": "player"},
                                  {"kind": "lit-string", "value": " wins!\n"}
                                ]
                              }
                            ]
                          },
                          "else_branch": {
                            "kind": "if",
                            "cond": {"kind": "var", "name": "is-draw"},
                            "then_branch": {"kind": "lit-string", "value": "\nIt's a draw!\n"},
                            "else_branch": {
                              "kind": "app", "fn": "string-concat",
                              "args": [
                                {"kind": "lit-string", "value": "\nPlayer "},
                                {"kind": "app", "fn": "string-concat",
                                  "args": [
                                    {"kind": "app", "fn": "next-player", "args": [{"kind": "var", "name": "player"}]},
                                    {"kind": "lit-string", "value": "'s turn (enter 0-8): "}
                                  ]
                                }
                              ]
                            }
                          }
                        }},
                        {"name": "output", "expr": {
                          "kind": "app", "fn": "string-concat",
                          "args": [
                            {"kind": "lit-string", "value": "\n"},
                            {"kind": "app", "fn": "string-concat",
                              "args": [
                                {"kind": "var", "name": "board-str"},
                                {"kind": "var", "name": "status-msg"}
                              ]
                            }
                          ]
                        }}
                      ],
                      "body": {
                        "kind": "pair",
                        "fst": {"kind": "var", "name": "new-state"},
                        "snd": {
                          "kind": "qual-app", "qual_fn": "wasi.io.stdout",
                          "args": [{"kind": "var", "name": "output"}]
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "game-step",
      "params": [
        {"name": "state", "untyped": true, "comment": "(list[string], (string, (bool, string)))"},
        {"name": "input", "param_type": {"kind": "primitive", "name": "string"}}
      ],
      "body": {
        "kind": "if",
        "cond": {"kind": "app", "fn": "state-gameover", "args": [{"kind": "var", "name": "state"}]},
        "then_branch": {
          "kind": "pair",
          "fst": {"kind": "var", "name": "state"},
          "snd": {
            "kind": "qual-app", "qual_fn": "wasi.io.stdout",
            "args": [{"kind": "lit-string", "value": "Game is over. Thanks for playing!\n"}]
          }
        },
        "else_branch": {
          "kind": "app", "fn": "make-move",
          "args": [{"kind": "var", "name": "state"}, {"kind": "var", "name": "input"}]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "game-done?",
      "params": [
        {"name": "state", "untyped": true, "comment": "(list[string], (string, (bool, string)))"}
      ],
      "body": {
        "kind": "app", "fn": "state-gameover",
        "args": [{"kind": "var", "name": "state"}]
      }
    },

    {
      "kind": "def-logic",
      "name": "init-game",
      "params": [],
      "body": {
        "kind": "let",
        "bindings": [
          {"name": "board",        "expr": {"kind": "app", "fn": "init-board",   "args": []}},
          {"name": "initial-state","expr": {"kind": "app", "fn": "make-state",   "args": [{"kind": "var", "name": "board"}, {"kind": "lit-string", "value": "X"}, {"kind": "lit-bool", "value": false}, {"kind": "lit-string", "value": ""}]}},
          {"name": "board-str",    "expr": {"kind": "app", "fn": "render-board","args": [{"kind": "var", "name": "board"}]}},
          {"name": "welcome",      "expr": {
            "kind": "app", "fn": "string-concat",
            "args": [
              {"kind": "lit-string", "value": "=== Tic-Tac-Toe ===\nPositions 0-8:\n 0 | 1 | 2\n---+---+---\n 3 | 4 | 5\n---+---+---\n 6 | 7 | 8\n\nCurrent board:\n"},
              {"kind": "app", "fn": "string-concat",
                "args": [
                  {"kind": "var", "name": "board-str"},
                  {"kind": "lit-string", "value": "\n\nPlayer X's turn (enter 0-8): "}
                ]
              }
            ]
          }}
        ],
        "body": {
          "kind": "pair",
          "fst": {"kind": "var", "name": "initial-state"},
          "snd": {
            "kind": "qual-app", "qual_fn": "wasi.io.stdout",
            "args": [{"kind": "var", "name": "welcome"}]
          }
        }
      }
    },

    {
      "kind": "def-main",
      "mode": "console",
      "init": {"kind": "app", "fn": "init-game", "args": []},
      "step": {"kind": "var", "name": "game-step"},
      "done?": {"kind": "var", "name": "game-done?"}
    }

  ]
}
