(module my_ttt
  (import wasi.io (capability stdout "console" :deterministic false))

  ;; Basic types
  (type Player (where [s: string] (or (= s "X") (= s "O"))))
  (type Cell   (where [s: string] (or (= s "X") (or (= s "O") (= s "-")))))

  ;; Helper: init list of length 9 with "-"
  (def-logic make-board []
    (let [[indices (range 0 9)]]
      (list-map indices (fn [i: int] "-"))))

  ;; Custom list-get
  (def-logic list-get [lst: list[string] target: int]
    (second
      (list-fold lst
                 (pair 0 "-")
                 (fn [acc item: string]
                   (let [[curr (first acc)]
                         [res  (second acc)]]
                     (if (= curr target)
                         (pair (+ curr 1) item)
                         (pair (+ curr 1) res)))))))

  ;; Custom list-set
  (def-logic list-set [lst: list[string] target: int val: string]
    (second
      (list-fold lst
                 (pair 0 (list-empty))
                 (fn [acc item: string]
                   (let [[curr (first acc)]
                         [new-lst (second acc)]]
                     (if (= curr target)
                         (pair (+ curr 1) (list-append new-lst val))
                         (pair (+ curr 1) (list-append new-lst item))))))))

  ;; Check line helper
  (def-logic check-win-line [board: list[string] i1: int i2: int i3: int]
    (let [[c1 (list-get board i1)]
          [c2 (list-get board i2)]
          [c3 (list-get board i3)]]
      (if (and (!= c1 "-") (and (= c1 c2) (= c2 c3)))
          c1
          "-")))

  ;; Check win
  (def-logic check-win [board: list[string]]
    (let [[w1 (check-win-line board 0 1 2)]
          [w2 (check-win-line board 3 4 5)]
          [w3 (check-win-line board 6 7 8)]
          [w4 (check-win-line board 0 3 6)]
          [w5 (check-win-line board 1 4 7)]
          [w6 (check-win-line board 2 5 8)]
          [w7 (check-win-line board 0 4 8)]
          [w8 (check-win-line board 2 4 6)]]
      (if (!= w1 "-") w1
      (if (!= w2 "-") w2
      (if (!= w3 "-") w3
      (if (!= w4 "-") w4
      (if (!= w5 "-") w5
      (if (!= w6 "-") w6
      (if (!= w7 "-") w7
      (if (!= w8 "-") w8
      "-"))))))))))

  ;; Check draw
  (def-logic is-draw [board: list[string]]
    (not (list-contains board "-")))

  ;; Format board
  (def-logic format-board [board: list[string]]
    (string-concat
      (string-concat (list-get board 0) (string-concat "|" (string-concat (list-get board 1) (string-concat "|" (string-concat (list-get board 2) "\n")))))
      (string-concat
        (string-concat (list-get board 3) (string-concat "|" (string-concat (list-get board 4) (string-concat "|" (string-concat (list-get board 5) "\n")))))
        (string-concat (list-get board 6) (string-concat "|" (string-concat (list-get board 7) (string-concat "|" (string-concat (list-get board 8) "\n")))))
      )))

  ;; Init state
  (def-logic init-game []
    (pair (make-board) "X"))

  ;; Toggle player
  (def-logic next-player [p: string]
    (if (= p "X") "O" "X"))

  (def-logic apply-move-logic [board: list[string] p: string idx: int]
    (let [[cell-val (list-get board idx)]]
      (if (= cell-val "-")
          (pair (list-set board idx p) (next-player p))
          (pair board p))))

  ;; Process turn
  (def-logic process-turn [state idx-str: string]
    (let [[board (first state)]
          [p (second state)]]
      (match (string-to-int idx-str)
        ((Success idx)
         (if (and (>= idx 0) (< idx 9))
             (let [[new-state (apply-move-logic board p idx)]
                   [new-board (first new-state)]
                   [winner (check-win new-board)]
                   [draw (is-draw new-board)]
                   [board-str (format-board new-board)]]
               (if (!= winner "-")
                   (pair new-state (wasi.io.stdout (string-concat board-str (string-concat winner " wins!\n"))))
                   (if draw
                       (pair new-state (wasi.io.stdout (string-concat board-str "Draw!\n")))
                       (pair new-state (wasi.io.stdout (string-concat board-str (string-concat "Player " (string-concat (second new-state) " next:\n"))))))))
             (pair state (wasi.io.stdout "Invalid move. Out of bounds.\n"))))
        ((Error e)
         (pair state (wasi.io.stdout "Invalid move. Not an integer.\n"))))))
)
