{
  "schemaVersion": "0.1.2",
  "llmll_version": "0.1.2",
  "source_file": "hangman.ast.json",
  "statements": [

    {
      "kind": "import",
      "path": "wasi.io",
      "capability": { "name": "stdin",  "deterministic": true }
    },
    {
      "kind": "import",
      "path": "wasi.io",
      "capability": { "name": "stdout", "deterministic": false }
    },

    {
      "kind": "type-decl",
      "name": "GameInput",
      "body": {
        "kind": "sum",
        "variants": [
          { "constructor": "StartGame", "payload": { "kind": "named", "name": "Word" } },
          { "constructor": "Guess",     "payload": { "kind": "named", "name": "Letter" } }
        ]
      }
    },

    {
      "kind": "type-decl",
      "name": "Word",
      "body": {
        "kind": "where",
        "binding": "s",
        "base_type": { "kind": "primitive", "name": "string" },
        "predicate": {
          "kind": "op", "op": ">",
          "args": [
            { "kind": "app", "fn": "string-length", "args": [{ "kind": "var", "name": "s" }] },
            { "kind": "lit-int", "value": 0 }
          ]
        }
      }
    },

    {
      "kind": "type-decl",
      "name": "Letter",
      "body": {
        "kind": "where",
        "binding": "s",
        "base_type": { "kind": "primitive", "name": "string" },
        "predicate": {
          "kind": "op", "op": "=",
          "args": [
            { "kind": "app", "fn": "string-length", "args": [{ "kind": "var", "name": "s" }] },
            { "kind": "lit-int", "value": 1 }
          ]
        }
      }
    },

    {
      "kind": "type-decl",
      "name": "GuessCount",
      "body": {
        "kind": "where",
        "binding": "n",
        "base_type": { "kind": "primitive", "name": "int" },
        "predicate": {
          "kind": "op", "op": ">=",
          "args": [
            { "kind": "var", "name": "n" },
            { "kind": "lit-int", "value": 0 }
          ]
        }
      }
    },

    {
      "kind": "type-decl",
      "name": "PositiveInt",
      "body": {
        "kind": "where",
        "binding": "x",
        "base_type": { "kind": "primitive", "name": "int" },
        "predicate": {
          "kind": "op", "op": ">",
          "args": [
            { "kind": "var", "name": "x" },
            { "kind": "lit-int", "value": 0 }
          ]
        }
      }
    },

    {
      "kind": "gen-decl",
      "type_name": "Letter",
      "body": {
        "kind": "app",
        "fn": "string-char-at",
        "args": [
          { "kind": "lit-string", "value": "abcdefghijklmnopqrstuvwxyz" },
          {
            "kind": "op", "op": "mod",
            "args": [
              { "kind": "app", "fn": "random-int", "args": [] },
              { "kind": "lit-int", "value": 26 }
            ]
          }
        ]
      }
    },

    {
      "kind": "def-logic",
      "name": "make-state",
      "params": [
        { "name": "word",    "param_type": { "kind": "named", "name": "Word" } },
        { "name": "guessed", "param_type": { "kind": "list",  "elem_type": { "kind": "named", "name": "Letter" } } },
        { "name": "wrong",   "param_type": { "kind": "named", "name": "GuessCount" } },
        { "name": "max-w",   "param_type": { "kind": "named", "name": "GuessCount" } }
      ],
      "body": {
        "kind": "pair",
        "fst": { "kind": "var", "name": "word" },
        "snd": {
          "kind": "pair",
          "fst": { "kind": "var", "name": "guessed" },
          "snd": {
            "kind": "pair",
            "fst": { "kind": "var", "name": "wrong" },
            "snd": { "kind": "var", "name": "max-w" }
          }
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "state-word",
      "params": [ { "name": "s" } ],
      "body": { "kind": "app", "fn": "first", "args": [{ "kind": "var", "name": "s" }] }
    },

    {
      "kind": "def-logic",
      "name": "state-guessed",
      "params": [ { "name": "s" } ],
      "body": {
        "kind": "app", "fn": "first",
        "args": [{
          "kind": "app", "fn": "second",
          "args": [{ "kind": "var", "name": "s" }]
        }]
      }
    },

    {
      "kind": "def-logic",
      "name": "state-wrong",
      "params": [ { "name": "s" } ],
      "body": {
        "kind": "app", "fn": "first",
        "args": [{
          "kind": "app", "fn": "second",
          "args": [{
            "kind": "app", "fn": "second",
            "args": [{ "kind": "var", "name": "s" }]
          }]
        }]
      }
    },

    {
      "kind": "def-logic",
      "name": "state-max",
      "params": [ { "name": "s" } ],
      "body": {
        "kind": "app", "fn": "second",
        "args": [{
          "kind": "app", "fn": "second",
          "args": [{
            "kind": "app", "fn": "second",
            "args": [{ "kind": "var", "name": "s" }]
          }]
        }]
      }
    },

    {
      "kind": "def-logic",
      "name": "word-chars",
      "params": [
        { "name": "word", "param_type": { "kind": "named", "name": "Word" } }
      ],
      "pre": {
        "kind": "op", "op": ">",
        "args": [
          { "kind": "app", "fn": "string-length", "args": [{ "kind": "var", "name": "word" }] },
          { "kind": "lit-int", "value": 0 }
        ]
      },
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "len",
            "expr": {
              "kind": "app", "fn": "string-length",
              "args": [{ "kind": "var", "name": "word" }]
            }
          },
          {
            "name": "indices",
            "expr": {
              "kind": "app", "fn": "range",
              "args": [
                { "kind": "lit-int", "value": 0 },
                { "kind": "var", "name": "len" }
              ]
            }
          }
        ],
        "body": {
          "kind": "app", "fn": "list-map",
          "args": [
            { "kind": "var", "name": "indices" },
            {
              "kind": "lambda",
              "params": [ { "name": "i", "param_type": { "kind": "primitive", "name": "int" } } ],
              "body": {
                "kind": "app", "fn": "string-char-at",
                "args": [
                  { "kind": "var", "name": "word" },
                  { "kind": "var", "name": "i" }
                ]
              }
            }
          ]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "display-word",
      "params": [
        { "name": "word",    "param_type": { "kind": "named", "name": "Word" } },
        { "name": "guessed", "param_type": { "kind": "list", "elem_type": { "kind": "named", "name": "Letter" } } }
      ],
      "post": {
        "kind": "op", "op": "=",
        "args": [
          {
            "kind": "app", "fn": "string-length",
            "args": [{ "kind": "var", "name": "result" }]
          },
          {
            "kind": "app", "fn": "string-length",
            "args": [{ "kind": "var", "name": "word" }]
          }
        ]
      },
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "chars",
            "expr": {
              "kind": "app", "fn": "word-chars",
              "args": [{ "kind": "var", "name": "word" }]
            }
          },
          {
            "name": "masked",
            "expr": {
              "kind": "app", "fn": "list-map",
              "args": [
                { "kind": "var", "name": "chars" },
                {
                  "kind": "lambda",
                  "params": [ { "name": "c", "param_type": { "kind": "primitive", "name": "string" } } ],
                  "body": {
                    "kind": "if",
                    "cond": {
                      "kind": "app", "fn": "list-contains",
                      "args": [
                        { "kind": "var", "name": "guessed" },
                        { "kind": "var", "name": "c" }
                      ]
                    },
                    "then_branch": { "kind": "var", "name": "c" },
                    "else_branch": { "kind": "lit-string", "value": "_" }
                  }
                }
              ]
            }
          }
        ],
        "body": {
          "kind": "app", "fn": "list-fold",
          "args": [
            { "kind": "var", "name": "masked" },
            { "kind": "lit-string", "value": "" },
            {
              "kind": "lambda",
              "params": [
                { "name": "acc", "param_type": { "kind": "primitive", "name": "string" } },
                { "name": "ch",  "param_type": { "kind": "primitive", "name": "string" } }
              ],
              "body": {
                "kind": "app", "fn": "string-concat",
                "args": [
                  { "kind": "var", "name": "acc" },
                  { "kind": "var", "name": "ch" }
                ]
              }
            }
          ]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "all-guessed?",
      "params": [
        { "name": "word",    "param_type": { "kind": "named", "name": "Word" } },
        { "name": "guessed", "param_type": { "kind": "list", "elem_type": { "kind": "named", "name": "Letter" } } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "chars",
            "expr": {
              "kind": "app", "fn": "word-chars",
              "args": [{ "kind": "var", "name": "word" }]
            }
          }
        ],
        "body": {
          "kind": "app", "fn": "list-fold",
          "args": [
            { "kind": "var", "name": "chars" },
            { "kind": "lit-bool", "value": true },
            {
              "kind": "lambda",
              "params": [
                { "name": "acc", "param_type": { "kind": "primitive", "name": "bool" } },
                { "name": "c",   "param_type": { "kind": "primitive", "name": "string" } }
              ],
              "body": {
                "kind": "op", "op": "and",
                "args": [
                  { "kind": "var", "name": "acc" },
                  {
                    "kind": "app", "fn": "list-contains",
                    "args": [
                      { "kind": "var", "name": "guessed" },
                      { "kind": "var", "name": "c" }
                    ]
                  }
                ]
              }
            }
          ]
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "guess",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } },
        { "name": "l",     "param_type": { "kind": "named",    "name": "Letter" } }
      ],
      "pre": {
        "kind": "op", "op": "and",
        "args": [
          {
            "kind": "op", "op": "<",
            "args": [
              { "kind": "app", "fn": "state-wrong", "args": [{ "kind": "var", "name": "state" }] },
              { "kind": "app", "fn": "state-max",   "args": [{ "kind": "var", "name": "state" }] }
            ]
          },
          {
            "kind": "op", "op": "not",
            "args": [{
              "kind": "app", "fn": "all-guessed?",
              "args": [
                { "kind": "app", "fn": "state-word",    "args": [{ "kind": "var", "name": "state" }] },
                { "kind": "app", "fn": "state-guessed", "args": [{ "kind": "var", "name": "state" }] }
              ]
            }]
          }
        ]
      },
      "post": {
        "kind": "op", "op": ">=",
        "args": [
          { "kind": "app", "fn": "state-wrong", "args": [{ "kind": "var", "name": "result" }] },
          { "kind": "app", "fn": "state-wrong", "args": [{ "kind": "var", "name": "state" }] }
        ]
      },
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "word",
            "expr": { "kind": "app", "fn": "state-word", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "guessed",
            "expr": { "kind": "app", "fn": "state-guessed", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "wrong",
            "expr": { "kind": "app", "fn": "state-wrong", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "max-w",
            "expr": { "kind": "app", "fn": "state-max", "args": [{ "kind": "var", "name": "state" }] }
          }
        ],
        "body": {
          "kind": "if",
          "cond": {
            "kind": "app", "fn": "list-contains",
            "args": [
              { "kind": "var", "name": "guessed" },
              { "kind": "var", "name": "l" }
            ]
          },
          "then_branch": { "kind": "var", "name": "state" },
          "else_branch": {
            "kind": "if",
            "cond": {
              "kind": "app", "fn": "string-contains",
              "args": [
                { "kind": "var", "name": "word" },
                { "kind": "var", "name": "l" }
              ]
            },
            "then_branch": {
              "kind": "app", "fn": "make-state",
              "args": [
                { "kind": "var", "name": "word" },
                {
                  "kind": "app", "fn": "list-append",
                  "args": [
                    { "kind": "var", "name": "guessed" },
                    { "kind": "var", "name": "l" }
                  ]
                },
                { "kind": "var", "name": "wrong" },
                { "kind": "var", "name": "max-w" }
              ]
            },
            "else_branch": {
              "kind": "app", "fn": "make-state",
              "args": [
                { "kind": "var", "name": "word" },
                {
                  "kind": "app", "fn": "list-append",
                  "args": [
                    { "kind": "var", "name": "guessed" },
                    { "kind": "var", "name": "l" }
                  ]
                },
                {
                  "kind": "op", "op": "+",
                  "args": [
                    { "kind": "var", "name": "wrong" },
                    { "kind": "lit-int", "value": 1 }
                  ]
                },
                { "kind": "var", "name": "max-w" }
              ]
            }
          }
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "game-lost?",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } }
      ],
      "body": {
        "kind": "op", "op": ">=",
        "args": [
          { "kind": "app", "fn": "state-wrong", "args": [{ "kind": "var", "name": "state" }] },
          { "kind": "app", "fn": "state-max",   "args": [{ "kind": "var", "name": "state" }] }
        ]
      }
    },

    {
      "kind": "def-logic",
      "name": "game-won?",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } }
      ],
      "body": {
        "kind": "app", "fn": "all-guessed?",
        "args": [
          { "kind": "app", "fn": "state-word",    "args": [{ "kind": "var", "name": "state" }] },
          { "kind": "app", "fn": "state-guessed", "args": [{ "kind": "var", "name": "state" }] }
        ]
      }
    },

    {
      "kind": "def-logic",
      "name": "game-status",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } }
      ],
      "body": {
        "kind": "if",
        "cond": { "kind": "app", "fn": "game-won?", "args": [{ "kind": "var", "name": "state" }] },
        "then_branch": { "kind": "lit-string", "value": "won" },
        "else_branch": {
          "kind": "if",
          "cond": { "kind": "app", "fn": "game-lost?", "args": [{ "kind": "var", "name": "state" }] },
          "then_branch": { "kind": "lit-string", "value": "lost" },
          "else_branch": { "kind": "lit-string", "value": "in-progress" }
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "render-state",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "word",
            "expr": { "kind": "app", "fn": "state-word", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "guessed",
            "expr": { "kind": "app", "fn": "state-guessed", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "wrong",
            "expr": { "kind": "app", "fn": "state-wrong", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "max-w",
            "expr": { "kind": "app", "fn": "state-max", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "display",
            "expr": {
              "kind": "app", "fn": "display-word",
              "args": [
                { "kind": "var", "name": "word" },
                { "kind": "var", "name": "guessed" }
              ]
            }
          },
          {
            "name": "status",
            "expr": { "kind": "app", "fn": "game-status", "args": [{ "kind": "var", "name": "state" }] }
          },
          {
            "name": "guessed-str",
            "expr": {
              "kind": "app", "fn": "list-fold",
              "args": [
                { "kind": "var", "name": "guessed" },
                { "kind": "lit-string", "value": "" },
                {
                  "kind": "lambda",
                  "params": [
                    { "name": "acc", "param_type": { "kind": "primitive", "name": "string" } },
                    { "name": "g",   "param_type": { "kind": "primitive", "name": "string" } }
                  ],
                  "body": {
                    "kind": "if",
                    "cond": {
                      "kind": "op", "op": "=",
                      "args": [
                        { "kind": "var", "name": "acc" },
                        { "kind": "lit-string", "value": "" }
                      ]
                    },
                    "then_branch": { "kind": "var", "name": "g" },
                    "else_branch": {
                      "kind": "app", "fn": "string-concat",
                      "args": [
                        {
                          "kind": "app", "fn": "string-concat",
                          "args": [
                            { "kind": "var", "name": "acc" },
                            { "kind": "lit-string", "value": " " }
                          ]
                        },
                        { "kind": "var", "name": "g" }
                      ]
                    }
                  }
                }
              ]
            }
          },
          {
            "name": "wrong-str",
            "expr": {
              "kind": "app", "fn": "string-concat",
              "args": [
                {
                  "kind": "app", "fn": "string-concat",
                  "args": [
                    { "kind": "app", "fn": "int-to-string", "args": [{ "kind": "var", "name": "wrong" }] },
                    { "kind": "lit-string", "value": " / " }
                  ]
                },
                { "kind": "app", "fn": "int-to-string", "args": [{ "kind": "var", "name": "max-w" }] }
              ]
            }
          }
        ],
        "body": {
          "kind": "app", "fn": "string-concat",
          "args": [
            {
              "kind": "app", "fn": "string-concat",
              "args": [
                { "kind": "lit-string", "value": "Word:    " },
                { "kind": "var", "name": "display" }
              ]
            },
            {
              "kind": "app", "fn": "string-concat",
              "args": [
                {
                  "kind": "app", "fn": "string-concat",
                  "args": [
                    { "kind": "lit-string", "value": "\nGuesses: " },
                    { "kind": "var", "name": "guessed-str" }
                  ]
                },
                {
                  "kind": "app", "fn": "string-concat",
                  "args": [
                    {
                      "kind": "app", "fn": "string-concat",
                      "args": [
                        { "kind": "lit-string", "value": "\nWrong:   " },
                        { "kind": "var", "name": "wrong-str" }
                      ]
                    },
                    {
                      "kind": "app", "fn": "string-concat",
                      "args": [
                        { "kind": "lit-string", "value": "\nStatus:  " },
                        {
                          "kind": "app", "fn": "string-concat",
                          "args": [
                            { "kind": "var", "name": "status" },
                            { "kind": "lit-string", "value": "\n" }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },

    {
      "kind": "def-interface",
      "name": "HangmanIO",
      "methods": [
        {
          "name": "get-word",
          "fn_type": {
            "kind": "fn-type",
            "params": [ { "name": "u", "param_type": { "kind": "primitive", "name": "unit" } } ],
            "return_type": { "kind": "named", "name": "Word" }
          }
        },
        {
          "name": "show-board",
          "fn_type": {
            "kind": "fn-type",
            "params": [ { "name": "board", "param_type": { "kind": "primitive", "name": "string" } } ],
            "return_type": { "kind": "primitive", "name": "unit" }
          }
        },
        {
          "name": "ask-guess",
          "fn_type": {
            "kind": "fn-type",
            "params": [
              { "name": "board", "param_type": { "kind": "primitive", "name": "string" } },
              { "name": "wrong", "param_type": { "kind": "primitive", "name": "int" } },
              { "name": "max",   "param_type": { "kind": "primitive", "name": "int" } }
            ],
            "return_type": { "kind": "named", "name": "Letter" }
          }
        },
        {
          "name": "show-result",
          "fn_type": {
            "kind": "fn-type",
            "params": [
              { "name": "status", "param_type": { "kind": "primitive", "name": "string" } },
              { "name": "word",   "param_type": { "kind": "named",    "name": "Word" } }
            ],
            "return_type": { "kind": "primitive", "name": "unit" }
          }
        }
      ]
    },

    {
      "kind": "def-logic",
      "name": "initialize-game",
      "params": [
        { "name": "word", "param_type": { "kind": "named", "name": "Word" } }
      ],
      "pre": {
        "kind": "op", "op": ">",
        "args": [
          { "kind": "app", "fn": "string-length", "args": [{ "kind": "var", "name": "word" }] },
          { "kind": "lit-int", "value": 0 }
        ]
      },
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "initial-state",
            "expr": {
              "kind": "app", "fn": "make-state",
              "args": [
                { "kind": "var", "name": "word" },
                { "kind": "app", "fn": "list-empty", "args": [] },
                { "kind": "lit-int", "value": 0 },
                { "kind": "lit-int", "value": 6 }
              ]
            }
          }
        ],
        "body": {
          "kind": "pair",
          "fst": { "kind": "var", "name": "initial-state" },
          "snd": {
            "kind": "qual-app",
            "qual_fn": "wasi.io.stdout",
            "args": [ { "kind": "lit-string", "value": "Game initialized.\n" } ]
          }
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "handle-guess",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } },
        { "name": "l",     "param_type": { "kind": "named",    "name": "Letter" } }
      ],
      "body": {
        "kind": "let",
        "bindings": [
          {
            "name": "new-state",
            "expr": {
              "kind": "app", "fn": "guess",
              "args": [
                { "kind": "var", "name": "state" },
                { "kind": "var", "name": "l" }
              ]
            }
          },
          {
            "name": "board",
            "expr": {
              "kind": "app", "fn": "render-state",
              "args": [{ "kind": "var", "name": "new-state" }]
            }
          }
        ],
        "body": {
          "kind": "pair",
          "fst": { "kind": "var", "name": "new-state" },
          "snd": {
            "kind": "qual-app",
            "qual_fn": "wasi.io.stdout",
            "args": [{ "kind": "var", "name": "board" }]
          }
        }
      }
    },

    {
      "kind": "def-logic",
      "name": "game-step",
      "params": [
        { "name": "state", "param_type": { "kind": "primitive", "name": "string" } },
        { "name": "input", "param_type": { "kind": "named",    "name": "GameInput" } }
      ],
      "body": {
        "kind": "match",
        "scrutinee": { "kind": "var", "name": "input" },
        "arms": [
          {
            "pattern": {
              "kind": "constructor",
              "constructor": "StartGame",
              "sub_patterns": [ { "kind": "bind", "name": "word" } ]
            },
            "body": {
              "kind": "app", "fn": "initialize-game",
              "args": [{ "kind": "var", "name": "word" }]
            }
          },
          {
            "pattern": {
              "kind": "constructor",
              "constructor": "Guess",
              "sub_patterns": [ { "kind": "bind", "name": "l" } ]
            },
            "body": {
              "kind": "if",
              "cond": {
                "kind": "op", "op": "=",
                "args": [
                  { "kind": "app", "fn": "game-status", "args": [{ "kind": "var", "name": "state" }] },
                  { "kind": "lit-string", "value": "in-progress" }
                ]
              },
              "then_branch": {
                "kind": "app", "fn": "handle-guess",
                "args": [
                  { "kind": "var", "name": "state" },
                  { "kind": "var", "name": "l" }
                ]
              },
              "else_branch": {
                "kind": "pair",
                "fst": { "kind": "var", "name": "state" },
                "snd": {
                  "kind": "qual-app",
                  "qual_fn": "wasi.io.stdout",
                  "args": [{
                    "kind": "app", "fn": "render-state",
                    "args": [{ "kind": "var", "name": "state" }]
                  }]
                }
              }
            }
          }
        ]
      }
    },

    {
      "kind": "check",
      "label": "Addition is commutative",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "a", "param_type": { "kind": "primitive", "name": "int" } },
          { "name": "b", "param_type": { "kind": "primitive", "name": "int" } }
        ],
        "body": {
          "kind": "op", "op": "=",
          "args": [
            { "kind": "op", "op": "+", "args": [{ "kind": "var", "name": "a" }, { "kind": "var", "name": "b" }] },
            { "kind": "op", "op": "+", "args": [{ "kind": "var", "name": "b" }, { "kind": "var", "name": "a" }] }
          ]
        }
      }
    },

    {
      "kind": "check",
      "label": "Addition is associative",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "a", "param_type": { "kind": "primitive", "name": "int" } },
          { "name": "b", "param_type": { "kind": "primitive", "name": "int" } },
          { "name": "c", "param_type": { "kind": "primitive", "name": "int" } }
        ],
        "body": {
          "kind": "op", "op": "=",
          "args": [
            {
              "kind": "op", "op": "+",
              "args": [
                { "kind": "op", "op": "+", "args": [{ "kind": "var", "name": "a" }, { "kind": "var", "name": "b" }] },
                { "kind": "var", "name": "c" }
              ]
            },
            {
              "kind": "op", "op": "+",
              "args": [
                { "kind": "var", "name": "a" },
                { "kind": "op", "op": "+", "args": [{ "kind": "var", "name": "b" }, { "kind": "var", "name": "c" }] }
              ]
            }
          ]
        }
      }
    },

    {
      "kind": "check",
      "label": "wrong-count is non-negative after a guess",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "w", "param_type": { "kind": "named", "name": "GuessCount" } }
        ],
        "body": {
          "kind": "op", "op": ">=",
          "args": [
            {
              "kind": "op", "op": "+",
              "args": [
                { "kind": "var", "name": "w" },
                { "kind": "lit-int", "value": 1 }
              ]
            },
            { "kind": "var", "name": "w" }
          ]
        }
      }
    },

    {
      "kind": "check",
      "label": "display-word length equals word length for a single-char word",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "c", "param_type": { "kind": "named", "name": "Letter" } }
        ],
        "body": {
          "kind": "op", "op": "=",
          "args": [
            {
              "kind": "app", "fn": "string-length",
              "args": [{
                "kind": "app", "fn": "display-word",
                "args": [
                  { "kind": "var", "name": "c" },
                  { "kind": "app", "fn": "list-empty", "args": [] }
                ]
              }]
            },
            {
              "kind": "app", "fn": "string-length",
              "args": [{ "kind": "var", "name": "c" }]
            }
          ]
        }
      }
    },

    {
      "kind": "check",
      "label": "correctly guessed letter appears revealed in display",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "c", "param_type": { "kind": "named", "name": "Letter" } }
        ],
        "body": {
          "kind": "let",
          "bindings": [
            {
              "name": "displayed",
              "expr": {
                "kind": "app", "fn": "display-word",
                "args": [
                  { "kind": "var", "name": "c" },
                  {
                    "kind": "app", "fn": "list-append",
                    "args": [
                      { "kind": "app", "fn": "list-empty", "args": [] },
                      { "kind": "var", "name": "c" }
                    ]
                  }
                ]
              }
            }
          ],
          "body": {
            "kind": "op", "op": "=",
            "args": [
              { "kind": "var", "name": "displayed" },
              { "kind": "var", "name": "c" }
            ]
          }
        }
      }
    },

    {
      "kind": "check",
      "label": "game-status after all letters guessed is 'won'",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "c", "param_type": { "kind": "named", "name": "Letter" } }
        ],
        "body": {
          "kind": "let",
          "bindings": [
            {
              "name": "state",
              "expr": {
                "kind": "app", "fn": "make-state",
                "args": [
                  { "kind": "var", "name": "c" },
                  {
                    "kind": "app", "fn": "list-append",
                    "args": [
                      { "kind": "app", "fn": "list-empty", "args": [] },
                      { "kind": "var", "name": "c" }
                    ]
                  },
                  { "kind": "lit-int", "value": 0 },
                  { "kind": "lit-int", "value": 6 }
                ]
              }
            }
          ],
          "body": {
            "kind": "op", "op": "=",
            "args": [
              { "kind": "app", "fn": "game-status", "args": [{ "kind": "var", "name": "state" }] },
              { "kind": "lit-string", "value": "won" }
            ]
          }
        }
      }
    },

    {
      "kind": "check",
      "label": "game-status after max-wrong guesses is 'lost'",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "c", "param_type": { "kind": "named", "name": "Letter" } }
        ],
        "body": {
          "kind": "let",
          "bindings": [
            {
              "name": "state",
              "expr": {
                "kind": "app", "fn": "make-state",
                "args": [
                  { "kind": "var", "name": "c" },
                  { "kind": "app", "fn": "list-empty", "args": [] },
                  { "kind": "lit-int", "value": 6 },
                  { "kind": "lit-int", "value": 6 }
                ]
              }
            }
          ],
          "body": {
            "kind": "op", "op": "=",
            "args": [
              { "kind": "app", "fn": "game-status", "args": [{ "kind": "var", "name": "state" }] },
              { "kind": "lit-string", "value": "lost" }
            ]
          }
        }
      }
    },

    {
      "kind": "check",
      "label": "range produces correct length",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "n", "param_type": { "kind": "named", "name": "PositiveInt" } }
        ],
        "body": {
          "kind": "op", "op": "=",
          "args": [
            {
              "kind": "app", "fn": "list-length",
              "args": [{
                "kind": "app", "fn": "range",
                "args": [
                  { "kind": "lit-int", "value": 0 },
                  { "kind": "var", "name": "n" }
                ]
              }]
            },
            { "kind": "var", "name": "n" }
          ]
        }
      }
    },

    {
      "kind": "check",
      "label": "word-chars has same length as word",
      "for_all": {
        "kind": "for-all",
        "bindings": [
          { "name": "c", "param_type": { "kind": "named", "name": "Letter" } }
        ],
        "body": {
          "kind": "op", "op": "=",
          "args": [
            {
              "kind": "app", "fn": "list-length",
              "args": [{
                "kind": "app", "fn": "word-chars",
                "args": [{ "kind": "var", "name": "c" }]
              }]
            },
            { "kind": "lit-int", "value": 1 }
          ]
        }
      }
    }

  ]
}
