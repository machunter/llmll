(module ttt3
  (def-logic init-board []
    "         ")

  (def-logic init-player []
    "X")

  (def-logic toggle-player [p: string]
    (if (= p "X") "O" "X"))
    
  (def-logic set-char [board: string i: int p: string]
    (let [[prefix (string-slice board 0 i)]
          [suffix (string-slice board (+ i 1) 9)]]
      (string-concat prefix (string-concat p suffix))))

  (def-logic is-valid-move [board: string i: int]
    (and (>= i 0) 
         (and (< i 9) 
              (= (string-char-at board i) " "))))

  (def-logic make-move-board [board: string p: string i: int]
    (if (is-valid-move board i)
        (set-char board i p)
        board))

  (def-logic make-move-player [board: string p: string i: int]
    (if (is-valid-move board i)
        (toggle-player p)
        p))

  (def-logic check-line [board: string p: string i1: int i2: int i3: int]
    (and (= (string-char-at board i1) p)
         (and (= (string-char-at board i2) p)
              (= (string-char-at board i3) p))))

  (def-logic is-winner [board: string p: string]
    (or (check-line board p 0 1 2)
    (or (check-line board p 3 4 5)
    (or (check-line board p 6 7 8)
    (or (check-line board p 0 3 6)
    (or (check-line board p 1 4 7)
    (or (check-line board p 2 5 8)
    (or (check-line board p 0 4 8)
        (check-line board p 2 4 6)))))))))

  (def-logic check-win [board: string]
    (if (is-winner board "X")
        "X"
        (if (is-winner board "O")
            "O"
            " ")))

  (def-logic is-board-full [board: string]
    (not (string-contains board " ")))
    
  (check "Toggle player flips X to O and O to X"
    (for-all [p: string]
      (if (or (= p "X") (= p "O"))
          (= (toggle-player (toggle-player p)) p)
          true)))
)
