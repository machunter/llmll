;; ============================================================
;; Tic-Tac-Toe in LLMLL v0.1.1
;;
;; Board:  a list[string] of 9 cells; each cell is " ", "X", or "O"
;;         Positions 1-9 (user-facing) map to indices 0-8 internally.
;;
;; State:  nested pairs  (board, (player, status))
;;           board   : list[string]    9-cell board
;;           player  : string          "X" or "O"   (whose turn it is)
;;           status  : string          "playing", "X", "O", or "draw"
;;
;; Key grammar constraints discovered (v0.1.1 compiler):
;;   - Pair types  (a, b)  are NOT supported in typed-param position.
;;     Use untyped params ( [s]  instead of  [s: (a,b)] ).
;;   - Lambda params in list-fold etc. must also be untyped when the
;;     accumulator type is a pair.
;;   - import / module only parse inside module blocks; in practice
;;     the compiler accepts wasi.io.stdout without a capability import
;;     in v0.1.1 (capability checking is a v0.2 feature).
;; ============================================================

;; ---- State constructor ----------------------------------------------

(def-logic make-state [board: list[string] player: string status: string]
  (pair board (pair player status)))

;; ---- State accessors (untyped s because pair-type in param fails) ---

(def-logic state-board   [s] (first s))
(def-logic state-player  [s] (first (second s)))
(def-logic state-status  [s] (second (second s)))

;; ---- Empty board: 9 cells all set to " " ---------------------------

(def-logic empty-board []
  (list-fold
    (range 0 9)
    (list-empty)
    (fn [acc i]
      (list-append acc " "))))

;; ---- cell-at: retrieve the string at index idx (0-based) ------------
;; Accumulator is (current-value, current-index) as a pair.
;; We use untyped lambda params because pair types are not parseable.

(def-logic cell-at [board: list[string] idx: int]
  (first
    (list-fold
      board
      (pair " " 0)
      (fn [acc cell]
        (let [[cur-val (first acc)]
              [cur-idx (second acc)]]
          (if (= cur-idx idx)
              (pair cell (+ cur-idx 1))
              (pair cur-val (+ cur-idx 1))))))))

;; ---- set-cell: build a new board with position idx set to mark -----

(def-logic set-cell [board: list[string] idx: int mark: string]
  (first
    (list-fold
      board
      (pair (list-empty) 0)
      (fn [acc cell]
        (let [[cur-board (first acc)]
              [cur-idx   (second acc)]]
          (if (= cur-idx idx)
              (pair (list-append cur-board mark) (+ cur-idx 1))
              (pair (list-append cur-board cell) (+ cur-idx 1))))))))

;; ---- Win-detection helpers -----------------------------------------

(def-logic three-in-row? [board: list[string] a: int b: int c: int mark: string]
  (and (= (cell-at board a) mark)
       (and (= (cell-at board b) mark)
            (= (cell-at board c) mark))))

(def-logic player-wins? [board: list[string] mark: string]
  (or (three-in-row? board 0 1 2 mark)
      (or (three-in-row? board 3 4 5 mark)
          (or (three-in-row? board 6 7 8 mark)
              (or (three-in-row? board 0 3 6 mark)
                  (or (three-in-row? board 1 4 7 mark)
                      (or (three-in-row? board 2 5 8 mark)
                          (or (three-in-row? board 0 4 8 mark)
                              (three-in-row? board 2 4 6 mark)))))))))

(def-logic board-full? [board: list[string]]
  (not (list-contains board " ")))

;; ---- Status computation after a move --------------------------------

(def-logic compute-status [board: list[string] last-player: string]
  (if (player-wins? board last-player)
      last-player
      (if (board-full? board)
          "draw"
          "playing")))

;; ---- Whose turn is next? --------------------------------------------

(def-logic next-player [current: string]
  (if (= current "X") "O" "X"))

;; ---- Apply a validated move -----------------------------------------
;; Pre: game is still in progress.

(def-logic apply-move [state idx: int]
  (pre (= (state-status state) "playing"))
  (let [[board      (state-board state)]
        [player     (state-player state)]
        [new-board  (set-cell board idx player)]
        [new-status (compute-status new-board player)]
        [new-player (if (= new-status "playing") (next-player player) player)]]
    (make-state new-board new-player new-status)))

;; ---- Is this move valid? (cell empty and in range 0-8) --------------

(def-logic valid-move? [board: list[string] idx: int]
  (and (>= idx 0)
       (and (< idx 9)
            (= (cell-at board idx) " "))))

;; ---- Rendering: one row of the board --------------------------------

(def-logic render-row [board: list[string] a: int b: int c: int]
  (string-concat " "
    (string-concat (cell-at board a)
      (string-concat " | "
        (string-concat (cell-at board b)
          (string-concat " | "
            (string-concat (cell-at board c) "\n")))))))

;; ---- Rendering: full board ------------------------------------------

(def-logic render-board [board: list[string]]
  (string-concat
    (render-row board 0 1 2)
    (string-concat "-----------\n"
      (string-concat
        (render-row board 3 4 5)
        (string-concat "-----------\n"
          (render-row board 6 7 8))))))

;; ---- Rendering: status message --------------------------------------

(def-logic render-status [status: string player: string]
  (if (= status "playing")
      (string-concat "Player " (string-concat player "'s turn. Enter 1-9: "))
      (if (= status "draw")
          "It's a draw!\n"
          (string-concat "Player " (string-concat status " wins!\n")))))

;; ---- Parse "1"-"9" raw input to 0-based index -----------------------

(def-logic parse-input [raw: string]
  (let [[digit  (string-slice raw 0 1)]
        [parsed (string-to-int digit)]]
    (match parsed
      ((Success n) (if (and (>= n 1) (<= n 9))
                       (ok (- n 1))
                       (err "out of range")))
      ((Error msg) (err "not a number")))))

;; ---- Initial game state (X goes first) ------------------------------

(def-logic initial-state []
  (make-state (empty-board) "X" "playing"))

;; ---- One game step: consume input, return (new-state, Command) ------

(def-logic game-step [state raw-input: string]
  (let [[board   (state-board state)]
        [player  (state-player state)]
        [status  (state-status state)]]
    (if (= status "playing")
        (let [[parsed (parse-input raw-input)]]
          (if (is-ok parsed)
              (let [[idx (unwrap parsed)]]
                (if (valid-move? board idx)
                    (let [[new-state  (apply-move state idx)]
                          [new-board  (state-board new-state)]
                          [new-status (state-status new-state)]
                          [new-player (state-player new-state)]
                          [board-str  (render-board new-board)]
                          [msg        (render-status new-status new-player)]]
                      (pair new-state
                            (wasi.io.stdout
                              (string-concat board-str
                                (string-concat "\n" msg)))))
                    (pair state
                          (wasi.io.stdout "That cell is already taken. Try again: "))))
              (pair state
                    (wasi.io.stdout "Invalid input. Enter a number 1-9: "))))
        (pair state
              (wasi.io.stdout "Game over. Restart to play again.\n")))))

;; ---- start-game: produce initial (state, welcome Command) -----------

(def-logic start-game []
  (let [[state  (initial-state)]
        [board  (state-board state)]
        [player (state-player state)]]
    (pair state
          (wasi.io.stdout
            (string-concat
              "=== Tic-Tac-Toe ===\nPositions are numbered 1-9:\n 1 | 2 | 3\n-----------\n 4 | 5 | 6\n-----------\n 7 | 8 | 9\n\n"
              (string-concat
                (render-board board)
                (string-concat "\n" (render-status "playing" player))))))))
