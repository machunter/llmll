;; Tic-Tac-Toe — S-expression version (LLMLL v0.1.3.1)
;; State: (board, turn)  board = list[string] of 9 cells, turn = "X" or "O"

;; ---------------------------------------------------------------------------
;; State accessors
;; ---------------------------------------------------------------------------

(def-logic state-board [s]
  (first s))

(def-logic state-turn [s]
  (second s))

(def-logic make-state [board turn: string]
  (pair board turn))

;; ---------------------------------------------------------------------------
;; Board helpers
;; ---------------------------------------------------------------------------

(def-logic cell-at [board idx: int]
  (unwrap-or (list-nth board idx) " "))

(def-logic set-cell [board target: int mark: string]
  (let [(indices (range 0 9))]
    (list-map indices
      (fn [i: int]
        (if (= i target)
            mark
            (cell-at board i))))))

;; ---------------------------------------------------------------------------
;; Win detection
;; ---------------------------------------------------------------------------

(def-logic three-match? [board a: int b: int c: int]
  (let [(ca (cell-at board a))
        (cb (cell-at board b))
        (cc (cell-at board c))
        (not-empty (!= ca " "))
        (ab-match (= ca cb))
        (ac-match (= ca cc))]
    (and not-empty (and ab-match ac-match))))

(def-logic winner? [board]
  (let [(r0 (three-match? board 0 1 2))
        (r1 (three-match? board 3 4 5))
        (r2 (three-match? board 6 7 8))
        (c0 (three-match? board 0 3 6))
        (c1 (three-match? board 1 4 7))
        (c2 (three-match? board 2 5 8))
        (d0 (three-match? board 0 4 8))
        (d1 (three-match? board 2 4 6))]
    (or r0 (or r1 (or r2 (or c0 (or c1 (or c2 (or d0 d1)))))))))

(def-logic board-full? [board]
  (not (list-contains board " ")))

(def-logic is-game-over? [s]
  (let [(board (state-board s))
        (won   (winner? board))
        (full  (board-full? board))]
    (or won full)))

;; ---------------------------------------------------------------------------
;; Board rendering — all list literals hoisted into let bindings
;; (§4.7 restriction: [..] inside if-branch body causes parse error)
;; ---------------------------------------------------------------------------

(def-logic render-board [board]
  (let [(c0  (cell-at board 0))
        (c1  (cell-at board 1))
        (c2  (cell-at board 2))
        (c3  (cell-at board 3))
        (c4  (cell-at board 4))
        (c5  (cell-at board 5))
        (c6  (cell-at board 6))
        (c7  (cell-at board 7))
        (c8  (cell-at board 8))
        (sep " | ")
        (ln  "\n-----------\n")
        (row0-parts [" " c0 sep c1 sep c2])
        (row1-parts [" " c3 sep c4 sep c5])
        (row2-parts [" " c6 sep c7 sep c8])
        (row0 (string-concat-many row0-parts))
        (row1 (string-concat-many row1-parts))
        (row2 (string-concat-many row2-parts))
        (all-parts ["\n" row0 ln row1 ln row2 "\n"])]
    (string-concat-many all-parts)))

;; ---------------------------------------------------------------------------
;; Player helpers
;; ---------------------------------------------------------------------------

(def-logic next-player [turn: string]
  (if (= turn "X") "O" "X"))

;; ---------------------------------------------------------------------------
;; Entry point
;; ---------------------------------------------------------------------------

(def-logic start-game []
  (let [(empty-board [" " " " " " " " " " " " " " " " " "])
        (init-state  (make-state empty-board "X"))
        (lines ["=== Tic-Tac-Toe ===\n"
                "Enter a position (1-9):\n"
                " 1 | 2 | 3\n-----------\n 4 | 5 | 6\n-----------\n 7 | 8 | 9\n\n"
                "Player X goes first. Enter position: "])
        (welcome (string-concat-many lines))]
    (pair init-state (wasi.io.stdout welcome))))

;; ---------------------------------------------------------------------------
;; Game loop — note: all [..] inside branches are hoisted to let above the if
;; ---------------------------------------------------------------------------

(def-logic build-prompt [next-turn: string won-now: bool full-now: bool]
  (if won-now
      ""
      (if full-now
          ""
          (let [(parts ["Player " next-turn "'s turn. Enter position: "])]
            (string-concat-many parts)))))

(def-logic game-loop [s input: string]
  (let [(board  (state-board s))
        (turn   (state-turn  s))
        (clean  (string-trim input))
        (parsed (string-to-int clean))]
    (match parsed
      ((Error _err)
       (pair s (wasi.io.stdout "Invalid input. Enter 1-9: ")))
      ((Success pos)
       (let [(idx          (- pos 1))
             (in-range     (and (>= idx 0) (< idx 9)))
             (current-cell (cell-at board idx))
             (cell-free    (= current-cell " "))
             (valid-move   (and in-range cell-free))]
         (if valid-move
             (let [(new-board  (set-cell board idx turn))
                   (next-turn  (next-player turn))
                   (new-state  (make-state new-board next-turn))
                   (board-str  (render-board new-board))
                   (won-now    (winner? new-board))
                   (full-now   (board-full? new-board))
                   (prompt     (build-prompt next-turn won-now full-now))
                   (out-parts  [board-str "\n" prompt])
                   (out        (string-concat-many out-parts))]
               (pair new-state (wasi.io.stdout out)))
             (if in-range
                 (pair s (wasi.io.stdout "Cell already taken. Enter another position: "))
                 (pair s (wasi.io.stdout "Position out of range. Enter 1-9: ")))))))))

;; ---------------------------------------------------------------------------
;; End-of-game message (:on-done hook)
;; ---------------------------------------------------------------------------

(def-logic show-result [s]
  (let [(board        (state-board s))
        (turn         (state-turn  s))
        (won          (winner? board))
        (prev-player  (next-player turn))
        (win-parts    ["Player " prev-player " wins! Congratulations!\n"])
        (win-msg      (string-concat-many win-parts))
        (draw-msg     "It's a draw! Well played!\n")
        (msg          (if won win-msg draw-msg))]
    (wasi.io.stdout msg)))

;; ---------------------------------------------------------------------------
;; Main
;; ---------------------------------------------------------------------------

(def-main
  :mode    console
  :init    (start-game)
  :step    game-loop
  :done?   is-game-over?
  :on-done show-result)
