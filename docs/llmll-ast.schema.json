{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmll.dev/schemas/v0.2/ast.schema.json",
  "title": "LLMLL v0.2 JSON-AST Schema",
  "description": "A JSON representation of the LLMLL Abstract Syntax Tree. Every .llmll source file must correspond to a JSON object validated against the top-level 'Program' definition. This schema is the machine-checked interface between AI code-generators and the LLMLL compiler pipeline.",

  "$defs": {

    "Program": {
      "description": "Top-level structure. A file is a flat list of statements (no implicit root module). Wrap in a module statement if namespacing is desired.",
      "type": "object",
      "required": ["schemaVersion", "llmll_version", "statements"],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "description": "Must be '0.2.0'. The compiler rejects files with an unrecognised version. Files pinned to '0.1.3' must update this field to compile with the v0.2 compiler.",
          "type": "string",
          "const": "0.2.0"
        },
        "llmll_version": {
          "description": "Must be '0.2.0'.",
          "type": "string",
          "const": "0.2.0"
        },
        "source_file": {
          "description": "Optional: original .llmll filename for diagnostics.",
          "type": "string"
        },
        "statements": {
          "type": "array",
          "items": { "$ref": "#/$defs/Statement" }
        }
      }
    },

    "Statement": {
      "description": "A top-level definition. Corresponds to EBNF 'statement'.",
      "oneOf": [
        { "$ref": "#/$defs/DefLogic" },
        { "$ref": "#/$defs/DefInterface" },
        { "$ref": "#/$defs/DefInvariant" },
        { "$ref": "#/$defs/TypeDecl" },
        { "$ref": "#/$defs/GenDecl" },
        { "$ref": "#/$defs/CheckDecl" },
        { "$ref": "#/$defs/ImportDecl" },
        { "$ref": "#/$defs/ModuleDecl" },
        { "$ref": "#/$defs/OpenDecl" },
        { "$ref": "#/$defs/ExportDecl" },
        { "$ref": "#/$defs/DefMain" },
        { "$ref": "#/$defs/TrustDecl" }
      ]
    },

    "DefLogic": {
      "description": "A pure function with optional pre/post contracts. Corresponds to EBNF 'def-logic'. Return type is always inferred — omit it.",
      "type": "object",
      "required": ["kind", "name", "params", "body"],
      "additionalProperties": false,
      "properties": {
        "kind":   { "type": "string", "const": "def-logic" },
        "name":   { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$" },
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/TypedParam" }
        },
        "pre":    { "$ref": "#/$defs/Expr", "description": "Precondition. Must be bool-typed. Absence means 'true'." },
        "post":   { "$ref": "#/$defs/Expr", "description": "Postcondition. Must be bool-typed. 'result' is in scope here only." },
        "body":   { "$ref": "#/$defs/Expr" }
      },
      "examples": [
        {
          "kind": "def-logic",
          "name": "withdraw",
          "params": [
            {"name": "balance", "type": {"kind": "primitive", "name": "int"}},
            {"name": "amount",  "type": {"kind": "named",    "name": "PositiveInt"}}
          ],
          "pre":  {"kind": "op", "op": ">=", "args": [{"kind": "var", "name": "balance"}, {"kind": "var", "name": "amount"}]},
          "post": {"kind": "op", "op": "=",  "args": [{"kind": "var", "name": "result"}, {"kind": "op", "op": "-", "args": [{"kind": "var", "name": "balance"}, {"kind": "var", "name": "amount"}]}]},
          "body": {"kind": "op", "op": "-", "args": [{"kind": "var", "name": "balance"}, {"kind": "var", "name": "amount"}]}
        }
      ]
    },

    "DefInterface": {
      "description": "A named interface (contract boundary). Corresponds to EBNF 'def-interface'.",
      "type": "object",
      "required": ["kind", "name", "methods"],
      "additionalProperties": false,
      "properties": {
        "kind":    { "type": "string", "const": "def-interface" },
        "name":    { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9_]*$" },
        "methods": {
          "type": "array",
          "items": { "$ref": "#/$defs/IfaceMethod" }
        }
      }
    },

    "IfaceMethod": {
      "description": "One method slot in a def-interface.",
      "type": "object",
      "required": ["name", "fn_type"],
      "additionalProperties": false,
      "properties": {
        "name":    { "type": "string" },
        "fn_type": { "$ref": "#/$defs/TypeFn" }
      }
    },

    "DefInvariant": {
      "description": "A module-level invariant. Stored and type-checked in v0.2; LiquidHaskell verification is Phase 2b.",
      "type": "object",
      "required": ["kind", "name", "param", "body"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "def-invariant" },
        "name":  { "type": "string" },
        "param": { "$ref": "#/$defs/TypedParam" },
        "body":  { "$ref": "#/$defs/Expr" }
      }
    },

    "TypeDecl": {
      "description": "A user-defined type: either a dependent (where) type or a sum type (ADT). Corresponds to EBNF 'type-decl'.",
      "type": "object",
      "required": ["kind", "name", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "type-decl" },
        "name": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9_]*$" },
        "body": {
          "oneOf": [
            { "$ref": "#/$defs/TypeWhere", "description": "Dependent type: (where [x: base] predicate)" },
            {
              "description": "Sum type / ADT: list of (| Constructor payload) arms",
              "type": "object",
              "required": ["kind", "variants"],
              "additionalProperties": false,
              "properties": {
                "kind": { "type": "string", "const": "sum" },
                "variants": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/Variant" }
                }
              }
            }
          ]
        }
      },
      "examples": [
        {
          "kind": "type-decl",
          "name": "Word",
          "body": {
            "kind": "where",
            "binding": "s",
            "base_type": {"kind": "primitive", "name": "string"},
            "predicate": {"kind": "op", "op": ">", "args": [{"kind": "app", "fn": "string-length", "args": [{"kind": "var", "name": "s"}]}, {"kind": "lit-int", "value": 0}]}
          }
        },
        {
          "kind": "type-decl",
          "name": "Color",
          "body": {
            "kind": "sum",
            "variants": [
              {"constructor": "Red",   "payload": {"kind": "primitive", "name": "unit"}},
              {"constructor": "Green", "payload": {"kind": "primitive", "name": "unit"}},
              {"constructor": "Blue",  "payload": {"kind": "primitive", "name": "unit"}}
            ]
          }
        }
      ]
    },

    "Variant": {
      "description": "One arm of a sum type.",
      "type": "object",
      "required": ["constructor", "payload"],
      "additionalProperties": false,
      "properties": {
        "constructor": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9_]*$" },
        "payload":     { "$ref": "#/$defs/Type" }
      }
    },

    "GenDecl": {
      "description": "A custom value generator for a dependent type. Used by the PBT engine. Corresponds to EBNF 'gen-decl'.",
      "type": "object",
      "required": ["kind", "type_name", "body"],
      "additionalProperties": false,
      "properties": {
        "kind":      { "type": "string", "const": "gen-decl" },
        "type_name": { "type": "string", "description": "The dependent type this generator produces values for." },
        "body":      { "$ref": "#/$defs/Expr", "description": "Expression yielding a value of the base type satisfying the dependent constraint." }
      }
    },

    "CheckDecl": {
      "description": "A property-based test. Must contain exactly one for-all. Corresponds to EBNF 'check'.",
      "type": "object",
      "required": ["kind", "label", "for_all"],
      "additionalProperties": false,
      "properties": {
        "kind":    { "type": "string", "const": "check" },
        "label":   { "type": "string" },
        "for_all": { "$ref": "#/$defs/ForAll" }
      }
    },

    "ForAll": {
      "description": "The single for-all body inside a check block.",
      "type": "object",
      "required": ["kind", "bindings", "body"],
      "additionalProperties": false,
      "properties": {
        "kind":     { "type": "string", "const": "for-all" },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/TypedParam" }
        },
        "body": { "$ref": "#/$defs/Expr" }
      }
    },

    "ImportDecl": {
      "description": "Capability or FFI import. In v0.2+, the compiler resolves user-module paths to source files. Built-in prefixes (wasi.*, haskell.*, c.*) are handled by the codegen preamble — no file lookup occurs. Use the 'hub.' prefix for registry packages.",
      "type": "object",
      "required": ["kind", "path"],
      "additionalProperties": false,
      "properties": {
        "kind":       { "type": "string", "const": "import" },
        "path":       { "type": "string", "description": "Dot-separated qualified path, e.g. 'wasi.io', 'haskell.aeson', or 'hub.llmll-crypto.hash.bcrypt'." },
        "capability": { "$ref": "#/$defs/CapabilitySpec" },
        "interface":  {
          "type": "array",
          "items": { "$ref": "#/$defs/IfaceMethod" },
          "description": "For FFI imports: the typed interface the foreign library exposes."
        }
      }
    },

    "CapabilitySpec": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name":          { "type": "string" },
        "path_or_port":  { "type": "string", "description": "e.g. '/data' for fs, '8080' for http." },
        "deterministic": { "type": "boolean", "default": false }
      }
    },

    "ModuleDecl": {
      "description": "An optional namespace wrapper. The module name is for documentation and tooling display only; the canonical module path is derived from the file's location relative to the source root (see LLMLL.md §8.1). Body is flattened during compilation.",
      "type": "object",
      "required": ["kind", "name", "imports", "statements"],
      "additionalProperties": false,
      "properties": {
        "kind":       { "type": "string", "const": "module" },
        "name":       { "type": "string" },
        "imports":    { "type": "array", "items": { "$ref": "#/$defs/ImportDecl" } },
        "statements": { "type": "array", "items": { "$ref": "#/$defs/Statement" } }
      }
    },

    "TypedParam": {
      "description": "A named, typed parameter. Pair-type in 'param_type' is supported since v0.2.",
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name":       { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$" },
        "param_type": { "$ref": "#/$defs/Type" },
        "untyped":    { "type": "boolean", "default": false, "description": "Legacy field — no longer needed since v0.2. Pair-type in param_type is fully supported." },
        "comment":    { "type": "string", "description": "When untyped=true, document the expected type here." }
      }
    },

    "Type": {
      "description": "Any LLMLL type expression. Corresponds to EBNF 'type'.",
      "oneOf": [
        { "$ref": "#/$defs/TypePrimitive" },
        { "$ref": "#/$defs/TypeList" },
        { "$ref": "#/$defs/TypeMap" },
        { "$ref": "#/$defs/TypeResult" },
        { "$ref": "#/$defs/TypePromise" },
        { "$ref": "#/$defs/TypeBytes" },
        { "$ref": "#/$defs/TypeFn" },
        { "$ref": "#/$defs/TypeWhere" },
        { "$ref": "#/$defs/TypePair" },
        { "$ref": "#/$defs/TypeCommand" },
        { "$ref": "#/$defs/TypeNamed" }
      ]
    },

    "TypePrimitive": {
      "type": "object",
      "required": ["kind", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "primitive" },
        "name": { "type": "string", "enum": ["int", "float", "string", "bool", "unit"] }
      }
    },

    "TypeList": {
      "type": "object",
      "required": ["kind", "elem_type"],
      "additionalProperties": false,
      "properties": {
        "kind":      { "type": "string", "const": "list" },
        "elem_type": { "$ref": "#/$defs/Type" }
      }
    },

    "TypeMap": {
      "type": "object",
      "required": ["kind", "key_type", "val_type"],
      "additionalProperties": false,
      "properties": {
        "kind":     { "type": "string", "const": "map" },
        "key_type": { "$ref": "#/$defs/Type" },
        "val_type": { "$ref": "#/$defs/Type" }
      }
    },

    "TypeResult": {
      "type": "object",
      "required": ["kind", "ok_type", "err_type"],
      "additionalProperties": false,
      "properties": {
        "kind":     { "type": "string", "const": "result" },
        "ok_type":  { "$ref": "#/$defs/Type" },
        "err_type": { "$ref": "#/$defs/Type" }
      }
    },

    "TypePromise": {
      "type": "object",
      "required": ["kind", "inner_type"],
      "additionalProperties": false,
      "properties": {
        "kind":       { "type": "string", "const": "promise" },
        "inner_type": { "$ref": "#/$defs/Type" }
      }
    },

    "TypeBytes": {
      "type": "object",
      "required": ["kind", "length"],
      "additionalProperties": false,
      "properties": {
        "kind":   { "type": "string", "const": "bytes" },
        "length": { "type": "integer", "minimum": 1 }
      }
    },

    "TypeFn": {
      "description": "A function type. Named params are documentation-only; both 'typed' and bare type arrays are valid.",
      "type": "object",
      "required": ["kind", "params", "return_type"],
      "additionalProperties": false,
      "properties": {
        "kind":        { "type": "string", "const": "fn-type" },
        "params":      {
          "type": "array",
          "items": { "$ref": "#/$defs/TypedParam" },
          "description": "Parameter types. Names are optional (doc-only)."
        },
        "return_type": { "$ref": "#/$defs/Type" }
      }
    },

    "TypeWhere": {
      "description": "A dependent type: (where [binding: base] predicate).",
      "type": "object",
      "required": ["kind", "binding", "base_type", "predicate"],
      "additionalProperties": false,
      "properties": {
        "kind":      { "type": "string", "const": "where" },
        "binding":   { "type": "string" },
        "base_type": { "$ref": "#/$defs/Type" },
        "predicate": { "$ref": "#/$defs/Expr" }
      }
    },

    "TypePair": {
      "description": "A 2-tuple product type: (a, b). v0.3 PR 1: now backed by TPair internally (distinct from Result in diagnostics and JSON-AST output).",
      "type": "object",
      "required": ["kind", "fst", "snd"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "pair-type" },
        "fst":  { "$ref": "#/$defs/Type" },
        "snd":  { "$ref": "#/$defs/Type" }
      }
    },

    "TypeCommand": {
      "description": "The opaque Command type. Cannot be pattern-matched.",
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "command" }
      }
    },

    "TypeNamed": {
      "description": "A user-defined type referenced by name, e.g. 'Word', 'PositiveInt', 'GameState'.",
      "type": "object",
      "required": ["kind", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "named" },
        "name": { "type": "string" }
      }
    },

    "Expr": {
      "description": "Any expression. Corresponds to EBNF 'expr'.",
      "oneOf": [
        { "$ref": "#/$defs/ExprLitInt" },
        { "$ref": "#/$defs/ExprLitFloat" },
        { "$ref": "#/$defs/ExprLitString" },
        { "$ref": "#/$defs/ExprLitBool" },
        { "$ref": "#/$defs/ExprVar" },
        { "$ref": "#/$defs/ExprLet" },
        { "$ref": "#/$defs/ExprIf" },
        { "$ref": "#/$defs/ExprMatch" },
        { "$ref": "#/$defs/ExprApp" },
        { "$ref": "#/$defs/ExprQualApp" },
        { "$ref": "#/$defs/ExprOp" },
        { "$ref": "#/$defs/ExprPair" },
        { "$ref": "#/$defs/ExprLambda" },
        { "$ref": "#/$defs/ExprAwait" },
        { "$ref": "#/$defs/ExprDo" },
        { "$ref": "#/$defs/ExprHole" },
        { "$ref": "#/$defs/ExprLitList" }
      ]
    },

    "ExprLitInt": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "lit-int" },
        "value": { "type": "integer" }
      }
    },

    "ExprLitFloat": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "lit-float" },
        "value": { "type": "number" }
      }
    },

    "ExprLitString": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "lit-string" },
        "value": {
          "type": "string",
          "description": "String content. RFC 8259 JSON escaping applies: use \\uXXXX for non-ASCII and control characters (e.g. \\u001b for ESC, \\n for newline). C-style \\xNN is not valid JSON and will cause a parse error."
        }
      }
    },

    "ExprLitBool": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "lit-bool" },
        "value": { "type": "boolean" }
      }
    },

    "ExprVar": {
      "description": "A variable reference. 'result' is only valid inside a post clause.",
      "type": "object",
      "required": ["kind", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "var" },
        "name": { "type": "string" }
      }
    },

    "ExprLet": {
      "description": "Sequential let bindings (let*). Each binding is in scope for all subsequent bindings and the body.",
      "type": "object",
      "required": ["kind", "bindings", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "let" },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["expr"],
            "additionalProperties": false,
            "properties": {
              "name":    { "type": "string", "description": "Simple binding: name = expr (ergonomic shorthand)" },
              "pattern": { "$ref": "#/$defs/Pattern", "description": "Destructuring binding: (pair x y) = expr" },
              "expr": { "$ref": "#/$defs/Expr" }
            },
            "oneOf": [
              { "required": ["name"] },
              { "required": ["pattern"] }
            ]
          }
        },
        "body": { "$ref": "#/$defs/Expr" }
      },
      "examples": [
        {
          "kind": "let",
          "bindings": [
            {"name": "x", "expr": {"kind": "lit-int", "value": 1}},
            {"name": "y", "expr": {"kind": "op", "op": "+", "args": [{"kind": "var", "name": "x"}, {"kind": "lit-int", "value": 1}]}}
          ],
          "body": {"kind": "var", "name": "y"}
        }
      ]
    },

    "ExprIf": {
      "description": "Conditional: (if cond then else). All three branches are required.",
      "type": "object",
      "required": ["kind", "cond", "then_branch", "else_branch"],
      "additionalProperties": false,
      "properties": {
        "kind":        { "type": "string", "const": "if" },
        "cond":        { "$ref": "#/$defs/Expr" },
        "then_branch": { "$ref": "#/$defs/Expr" },
        "else_branch": { "$ref": "#/$defs/Expr" }
      }
    },

    "ExprMatch": {
      "description": "Pattern match. MUST be exhaustive — include a catch-all arm (\"_\") if needed.",
      "type": "object",
      "required": ["kind", "scrutinee", "arms"],
      "additionalProperties": false,
      "properties": {
        "kind":      { "type": "string", "const": "match" },
        "scrutinee": { "$ref": "#/$defs/Expr" },
        "arms": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/MatchArm" }
        }
      }
    },

    "MatchArm": {
      "type": "object",
      "required": ["pattern", "body"],
      "additionalProperties": false,
      "properties": {
        "pattern": { "$ref": "#/$defs/Pattern" },
        "body":    { "$ref": "#/$defs/Expr" }
      }
    },

    "Pattern": {
      "description": "A match pattern. Corresponds to EBNF 'pattern'.",
      "oneOf": [
        {
          "description": "Catch-all wildcard: _",
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": { "kind": { "type": "string", "const": "wildcard" } }
        },
        {
          "description": "Variable binding: captures the value.",
          "type": "object",
          "required": ["kind", "name"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "bind" },
            "name": { "type": "string" }
          }
        },
        {
          "description": "Literal equality: match a specific value.",
          "type": "object",
          "required": ["kind", "value"],
          "additionalProperties": false,
          "properties": {
            "kind":  { "type": "string", "const": "literal" },
            "value": { "oneOf": [{"type": "integer"}, {"type": "number"}, {"type": "string"}, {"type": "boolean"}] }
          }
        },
        {
          "description": "Constructor pattern: (ConstructorName sub-patterns...).",
          "type": "object",
          "required": ["kind", "constructor"],
          "additionalProperties": false,
          "properties": {
            "kind":        { "type": "string", "const": "constructor" },
            "constructor": { "type": "string" },
            "sub_patterns": {
              "type": "array",
              "items": { "$ref": "#/$defs/Pattern" }
            }
          }
        }
      ]
    },

    "ExprApp": {
      "description": "A plain function call: (fn-name arg1 arg2 ...). Use for user-defined def-logic and built-in stdlib functions.",
      "type": "object",
      "required": ["kind", "fn", "args"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "app" },
        "fn":   { "type": "string", "description": "Name of the function. ASCII only. No dots." },
        "args": { "type": "array", "items": { "$ref": "#/$defs/Expr" } }
      }
    },

    "ExprQualApp": {
      "description": "A qualified capability call: (wasi.io.stdout ...). Use for command constructors.",
      "type": "object",
      "required": ["kind", "qual_fn", "args"],
      "additionalProperties": false,
      "properties": {
        "kind":    { "type": "string", "const": "qual-app" },
        "qual_fn": { "type": "string", "description": "Dot-separated qualified name, e.g. 'wasi.io.stdout'." },
        "args":    { "type": "array", "items": { "$ref": "#/$defs/Expr" } }
      }
    },

    "ExprOp": {
      "description": "A built-in operator: +, -, *, /, =, !=, <, >, <=, >=, and, or, not, mod.",
      "type": "object",
      "required": ["kind", "op", "args"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "op" },
        "op":   {
          "type": "string",
          "enum": ["+", "-", "*", "/", "=", "!=", "<", ">", "<=", ">=", "and", "or", "not", "mod"]
        },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/Expr" },
          "description": "Unary ops (not) take 1 arg. All others take exactly 2."
        }
      }
    },

    "ExprPair": {
      "description": "A 2-tuple constructor: (pair fst snd).",
      "type": "object",
      "required": ["kind", "fst", "snd"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "pair" },
        "fst":  { "$ref": "#/$defs/Expr" },
        "snd":  { "$ref": "#/$defs/Expr" }
      }
    },

    "ExprLambda": {
      "description": "An anonymous function: (fn [params] body).",
      "type": "object",
      "required": ["kind", "params", "body"],
      "additionalProperties": false,
      "properties": {
        "kind":   { "type": "string", "const": "lambda" },
        "params": { "type": "array", "items": { "$ref": "#/$defs/TypedParam" } },
        "body":   { "$ref": "#/$defs/Expr" }
      }
    },

    "ExprAwait": {
      "description": "Await a Promise[t]: (await promise-expr). The expression's inferred type is Result[t, DelegationError], not bare t. The generated code wraps Async.wait in exception handling so agent failures are captured as Result.Error rather than propagating as uncaught exceptions. Breaking change from v0.2 where await returned bare t.",
      "type": "object",
      "required": ["kind", "expr"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "await" },
        "expr": { "$ref": "#/$defs/Expr" }
      }
    },

    "ExprDo": {
      "description": "Monadic do-notation: a sequence of bound steps and plain expressions.",
      "type": "object",
      "required": ["kind", "steps"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "do" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/DoStep" }
        }
      }
    },

    "DoStep": {
      "description": "A single step in a do-block (PR 2: unified form). Named steps bind the state component; anonymous steps discard it (state-loss hazard if non-terminal). Old kinds 'bind-step' and 'expr-step' are rejected with a migration error pointing to 'do-step'.",
      "type": "object",
      "required": ["kind", "expr"],
      "additionalProperties": false,
      "properties": {
        "kind":       { "type": "string", "const": "do-step" },
        "expr":       { "$ref": "#/$defs/Expr" },
        "name":       { "type": "string", "description": "If present, bound to the state component of expr's result (former bind-step). If absent, the state component is discarded (former expr-step)." },
        "state_type": { "$ref": "#/$defs/Type", "description": "Optional hint: the state type S. Required only when expr itself is a hole." }
      }
    },

    "ExprLitList": {
      "description": "List literal: [a, b, c]. Desugared by the parser to nested list-prepend calls.",
      "type": "object",
      "required": ["kind", "items"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "lit-list" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/Expr" } }
      },
      "examples": [
        { "kind": "lit-list", "items": [] },
        { "kind": "lit-list", "items": [
            { "kind": "lit-string", "value": " " },
            { "kind": "lit-string", "value": " " },
            { "kind": "lit-string", "value": " " }
        ]}
      ]
    },

    "ExprHole": {
      "description": "A typed hole. Can be named, a choice, a capability request, a scaffold, or a delegation.",
      "oneOf": [
        {
          "description": "?name — named placeholder.",
          "type": "object",
          "required": ["kind", "name"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "hole-named" },
            "name": { "type": "string" }
          }
        },
        {
          "description": "?choose(a, b, c) — option selection.",
          "type": "object",
          "required": ["kind", "options"],
          "additionalProperties": false,
          "properties": {
            "kind":    { "type": "string", "const": "hole-choose" },
            "options": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "description": "?request-cap(path) — request a new capability from the operator.",
          "type": "object",
          "required": ["kind", "cap_path"],
          "additionalProperties": false,
          "properties": {
            "kind":     { "type": "string", "const": "hole-request-cap" },
            "cap_path": { "type": "string" }
          }
        },
        {
          "description": "?scaffold — cold-start a module from a known template.",
          "type": "object",
          "required": ["kind", "template"],
          "additionalProperties": false,
          "properties": {
            "kind":     { "type": "string", "const": "hole-scaffold" },
            "template": { "type": "string" },
            "options":  { "type": "object", "additionalProperties": true }
          }
        },
        {
          "description": "?delegate — blocking delegation to a named agent.",
          "type": "object",
          "required": ["kind", "agent", "description", "return_type"],
          "additionalProperties": false,
          "properties": {
            "kind":        { "type": "string", "const": "hole-delegate" },
            "agent":       { "type": "string" },
            "description": { "type": "string" },
            "return_type": { "$ref": "#/$defs/Type" },
            "on_failure":  { "$ref": "#/$defs/Expr" }
          }
        },
        {
          "description": "?delegate-async — non-blocking delegation, returns Promise[T].",
          "type": "object",
          "required": ["kind", "agent", "description", "return_type"],
          "additionalProperties": false,
          "properties": {
            "kind":        { "type": "string", "const": "hole-delegate-async" },
            "agent":       { "type": "string" },
            "description": { "type": "string" },
            "return_type": { "$ref": "#/$defs/Type" }
          }
        },
        {
          "description": "?proof-required — Phase 2b. Emitted by the compiler for pre/post constraints outside the QF linear arithmetic fragment, or for letrec :decreases measures that are not simple variables. Also valid as a manual annotation. Non-blocking: code compiles with a runtime assertion fallback. See LLMLL.md §6 and getting-started.md §4.11.",
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind":   { "type": "string", "const": "hole-proof-required" },
            "reason": {
              "type": "string",
              "enum": ["manual", "non-linear-contract", "complex-decreases"],
              "default": "manual",
              "description": "Why this hole was emitted. 'manual' = authored by agent; others = compiler-emitted."
            }
          },
          "examples": [
            { "kind": "hole-proof-required", "reason": "non-linear-contract" },
            { "kind": "hole-proof-required", "reason": "complex-decreases" },
            { "kind": "hole-proof-required" }
          ]
        }
      ]
    },


    "OpenDecl": {
      "description": "Pull a module's exports into the current scope without a prefix. NEW in v0.2. Corresponds to EBNF 'open-decl' (LLMLL.md §8.6).",
      "type": "object",
      "required": ["kind", "path"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "open" },
        "path":  { "type": "string", "description": "Dot-separated module path to open, e.g. 'app.auth'." },
        "names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Selective open: only these names are brought into scope. Omit to open all exports."
        }
      },
      "examples": [
        { "kind": "open", "path": "app.auth" },
        { "kind": "open", "path": "app.auth", "names": ["hash-password", "verify-token"] }
      ]
    },

    "ExportDecl": {
      "description": "Restrict the names exported by this module to those listed. NEW in v0.2. If absent, all top-level defs are exported. Corresponds to EBNF 'export-decl' (LLMLL.md §8.7).",
      "type": "object",
      "required": ["kind", "names"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "type": "string", "const": "export" },
        "names": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Names of def-logic, type, def-interface, or gen declarations to export. check and def-invariant are never exported."
        }
      },
      "examples": [
        { "kind": "export", "names": ["hash-password", "verify-token"] }
      ]
    },

    "DefMain": {
      "description": "Declares the program entry point and runtime harness. Corresponds to EBNF 'def-main' (§9.5 LLMLL.md). Without a def-main the compiler generates a library only. At most one def-main per program.",
      "type": "object",
      "required": ["kind", "mode", "step"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "def-main" },
        "mode": {
          "description": "Selects the generated harness template.",
          "oneOf": [
            { "type": "string", "enum": ["console", "cli"] },
            {
              "type": "object",
              "required": ["kind", "port"],
              "additionalProperties": false,
              "properties": {
                "kind": { "type": "string", "const": "http" },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
              }
            }
          ]
        },
        "init": {
          "description": "Expression returning (State, Command) pair. Executed once at startup. Optional — if absent the initial state is ().",
          "$ref": "#/$defs/Expr"
        },
        "step": {
          "description": "Function or expression of type (State, String) -> (State, Command). Called on each input line (console) or OS args (cli).",
          "$ref": "#/$defs/Expr"
        },
        "read": {
          "description": "Custom input reader expression (optional, console only).",
          "$ref": "#/$defs/Expr"
        },
        "done?": {
          "description": "Predicate of type State -> Bool. When true the console loop exits (optional).",
          "$ref": "#/$defs/Expr"
        },
        "on-done": {
          "description": "Function of type State -> Command called once when done? returns true (optional).",
          "$ref": "#/$defs/Expr"
        }
      }
    },

    "PatchEnvelope": {
      "description": "LLMLL patch request envelope (v0.3). Submitted to 'llmll patch' CLI or POST /patch HTTP endpoint. Not part of the AST schema proper — companion definition for agent tooling.",
      "type": "object",
      "required": ["token", "patch"],
      "additionalProperties": false,
      "properties": {
        "token": { "type": "string", "description": "Checkout bearer token from 'llmll checkout'." },
        "patch": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatchOp" },
          "description": "RFC 6902 operations to apply to the JSON-AST."
        }
      }
    },

    "PatchOp": {
      "description": "A single RFC 6902 JSON-Patch operation (v0.3). Supported ops: replace, add, remove, test. 'move' and 'copy' are deferred to v0.4.",
      "type": "object",
      "required": ["op", "path"],
      "additionalProperties": false,
      "properties": {
        "op":    { "type": "string", "enum": ["replace", "add", "remove", "test"] },
        "path":  { "type": "string", "description": "RFC 6901 JSON Pointer targeting a node within the checked-out subtree." },
        "value": { "description": "The value to use for replace/add/test. Required for replace, add, test. Must be absent for remove." }
      },
      "if": { "properties": { "op": { "enum": ["replace", "add", "test"] } } },
      "then": { "required": ["value"] }
    },

    "CheckoutToken": {
      "description": "Checkout token response from 'llmll checkout' or POST /checkout (v0.3; context-aware v0.3.5). Companion definition for agent tooling.",
      "type": "object",
      "required": ["pointer", "token", "ttl"],
      "additionalProperties": true,
      "properties": {
        "pointer":   { "type": "string", "description": "RFC 6901 JSON Pointer to the checked-out hole. Normalized: leading zeros in numeric segments are stripped (EC-3)." },
        "hole_kind": { "type": "string", "description": "The kind of hole (e.g. 'hole-delegate', 'hole-named')." },
        "token":     { "type": "string", "description": "32-character hex bearer token. Include in patch requests." },
        "ttl":       { "type": "integer", "description": "Lock time-to-live in seconds. Default: 3600 (1 hour)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Lock creation time (ISO 8601)." },
        "in_scope": {
          "description": "v0.3.5: Bindings visible at the hole site (Γ delta). Sorted by source priority; may be truncated.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "source"],
            "properties": {
              "name":   { "type": "string" },
              "type":   { "type": "string", "description": "LLMLL type notation (e.g. 'list[int]', '(int, string)')." },
              "source": { "type": "string", "enum": ["param", "let-binding", "match-arm", "open-import"] }
            }
          }
        },
        "expected_return_type": { "type": "string", "description": "v0.3.5: Inferred return type at the hole site (τ as LLMLL type label)." },
        "available_functions": {
          "description": "v0.3.5: Non-wasi.* function signatures (Σ), monomorphized against concrete scope types.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "params", "returns", "status"],
            "properties": {
              "name":    { "type": "string" },
              "params":  { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string" } } } },
              "returns": { "type": "string" },
              "status":  { "type": "string", "enum": ["filled", "hole", "builtin"] }
            }
          }
        },
        "type_definitions": {
          "description": "v0.3.5: User-defined type aliases and sum types referenced by in-scope bindings. Depth-bounded expansion (max 5 levels) with cycle detection.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "kind"],
            "properties": {
              "name":         { "type": "string" },
              "kind":         { "type": "string", "enum": ["sum", "alias", "dependent"] },
              "constructors": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "payload": { "type": "string" } } } },
              "base_type":    { "type": "string" },
              "recursive":    { "type": "boolean", "description": "True if cycle detected during alias expansion (EC-4)." }
            }
          }
        },
        "scope_truncated": { "type": "boolean", "description": "v0.3.5: True if in_scope was truncated to the 50-entry limit (C6)." }
      }
    },

    "TrustDecl": {
      "description": "Trust acknowledgment for an imported function's unproven contract (v0.3, \u00a74.4.3). Silences TrustGapWarning diagnostics. Must appear before any def-logic. Multiple trust declarations per module are allowed; duplicates are idempotent.",
      "type": "object",
      "required": ["kind", "target", "level"],
      "additionalProperties": false,
      "properties": {
        "kind":   { "type": "string", "const": "trust" },
        "target": { "type": "string", "description": "Dot-separated qualified function name, e.g. 'crypto.hash.pbkdf2'." },
        "level":  { "type": "string", "enum": ["proven", "tested", "asserted"], "description": "The verification level being acknowledged. Sample counts for 'tested' are compiler-internal (stored in sidecar .verified.json, not in surface syntax)." }
      },
      "examples": [
        { "kind": "trust", "target": "crypto.hash.pbkdf2", "level": "asserted" },
        { "kind": "trust", "target": "auth.verify-token", "level": "tested" }
      ]
    }

  },

  "$ref": "#/$defs/Program"
}
